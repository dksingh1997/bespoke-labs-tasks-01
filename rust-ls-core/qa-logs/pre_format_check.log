ask.toml","text":"version = \"1.0\"\n\n[metadata]\ndifficulty = \"medium\"\ncategory = \"programming\"\ntags = [\"rust\", \"ls\", \"coreutils\", \"systems\", \"cli\", \"file-listing\", \"posix\", \"core\", \"milestone\"]\n\n[agent]\ntimeout_sec = 7200.0\nuser = \"agent\"\n\n[verifier]\ntimeout_sec = 3600.0\n\n[environment]\nbuild_timeout_sec = 600.0\ncpus = 2\nmemory_mb = 8192\nstorage_mb = 10240\ngpus = 0\nallow_internet = false\nmcp_servers = []\n\n[verifier.env]\n\n[solution.env]\n# Injected ONLY into oracle runs. solve.sh writes this token to an oracle marker\n# file and test.sh matches it to skip anti-cheat, because the oracle decrypts the\n# baked oracle `ls` as its solution. The agent never sees this value, so it cannot\n# forge the marker (replaces the old forgeable bare-existence .oracle_solution).\nHARBOR_ORACLE_FLAG = \"rustls_core_24b837b47b882795\"","lineStart":1,"lineEnd":31,"totalLines":31,"truncated":false}},"title":"rust-ls-core/task.toml","time":{"start":1781081859850,"end":1781081859882}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_eb0c06594001AWvn267rM58ZZP","sessionID":"ses_14f3fd98fffevHhVBuLsS29mAo","messageID":"msg_eb0c058c3001dfpWWXFCKXtEQD"}}
