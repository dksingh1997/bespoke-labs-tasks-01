[6.346186, "o", "cat /app/src/aisc_d2/__init__.py\r\n\u001b[?2004l\r"]
[6.350551, "o", "from .tension import tensile_strength\r\n\r\n__all__ = [\"tensile_strength\"]\r\n\u001b[?2004hroot@199c3d4c588a:/app# "]
[14.354829, "i", "cat > /app/src/aisc_d2/tension.py << 'EOF'\ndef tensile_strength(Ag: float, Ae: float, Fy: float, Fu: float, method: str = \"LRFD\") -> dict:\n    if not isinstance(method, str):\n        raise ValueError(\"method must be 'LRFD' or 'ASD'\")\n    m = method.strip().upper()\n    if m not in (\"LRFD\", \"ASD\"):\n        raise ValueError(\"method must be 'LRFD' or 'ASD'\")\n\n    Pn_yield = Fy * Ag\n    Pn_rupture = Fu * Ae\n\n    if m == \"LRFD\":\n        Pa_yield = 0.90 * Pn_yield\n        Pa_rupture = 0.75 * Pn_rupture\n    else:\n        Pa_yield = Pn_yield / 1.67\n        Pa_rupture = Pn_rupture / 2.00\n\n    Pn = min(Pn_yield, Pn_rupture)\n    Pa = min(Pa_yield, Pa_rupture)\n    controls = \"yielding\" if Pa_yield <= Pa_rupture else \"rupture\"\n\n    return {\n        \"Pn_yield\": Pn_yield,\n        \"Pn_rupture\": Pn_rupture,\n        \"Pn\": Pn,\n        \"Pa\": Pa,\n        \"controls\": controls,\n    }\nEOF\n"]
