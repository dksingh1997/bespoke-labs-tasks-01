# Harbor job outputs
jobs/

# Secrets file (API keys)
.env

# TCC build artifacts (in environment/compiler-src/tcc/ and tests/baseline-tcc/)
*.o
*.a
*.exe
# Ignore ONLY the compiled `tcc` binary at the root of each source tree — a bare
# `tcc` pattern also matches the environment/compiler-src/tcc/ SOURCE directory,
# which must stay tracked so the Docker build context contains it.
/environment/compiler-src/tcc/tcc
/tests/baseline-tcc/tcc
libtcc.so*
libtcc.dylib*
config.h
config.mak
config.texi
tcc-doc.info
tcc-doc.html
c2str
c2str.exe

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs and temp files
*.log
/tmp/
