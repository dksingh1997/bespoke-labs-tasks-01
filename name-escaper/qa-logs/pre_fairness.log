 8)\n610:    add(\"t8_override_1_then_C\", \"basic\", [\"-1\", \"-C\"], 8)\n667:    1: \"tier1_basic\",\n713:        expected = normalize_output(stdout)\n715:        # Save expected output\n716:        exp_path = os.path.join(EXPECTED_DIR, f\"{name}.expected\")\n718:            f.write(expected)\n757:    create_examples()\n760:def create_examples():\n761:    \"\"\"Copy a small subset of fixtures + expected outputs to workspace/examples.\"\"\"\n762:    examples_dir = EXAMPLES_SRC\n763:    os.makedirs(os.path.join(examples_dir, \"expected\"), exist_ok=True)\n765:    # Copy basic fixture (only if this scope actually built it; some scopes —\n766:    # e.g. the performance tier — do not use the `basic` fixture at all).\n767:    src = os.path.join(FIXTURES_DIR, \"basic\")\n768:    dst = os.path.join(examples_dir, \"basic\")\n770:        print(\"  (no 'basic' fixture in scope; skipping workspace examples)\")\n776:    # Copy up to a handful of in-scope expected outputs for the basic fixture.\n778:    # if the basic fixture is not used by this scope, nothing is copied.\n780:    basic_expected = sorted(_glob.glob(os.path.join(EXPECTED_DIR, \"t*_basic_*.expected\")))\n781:    for src_f in basic_expected[:6]:\n782:        base = os.path.basename(src_f)[: -len(\".expected\")]\n783:        shutil.copy2(src_f, os.path.join(examples_dir, \"expected\", f\"{base}.txt\"))\n785:    print(f\"  Examples written to {examples_dir}\")\n","metadata":{"output":"3:Generate test fixtures and expected outputs for the rust-ls RL environment.\n6:GNU ls on each with various flag combinations, and saves expected outputs\n19:FIXTURES_DIR = \"/app/fixtures\"\n20:TESTS_DIR = \"/app/tests\"\n21:EXPECTED_DIR = \"/expected\"\n22:EXAMPLES_SRC = \"/app/workspace/examples\"\n90:def create_fixture_basic():\n91:    d = os.path.join(FIXTURES_DIR, \"basic\")\n331:    \"basic\": create_fixture_basic,\n391:    for fx in [\"basic\", \"dotfiles\", \"empty\", \"many\", \"mixed\"]:\n400:    for fx in [\"basic\", \"dotfiles\", \"permissions\", \"sizes\", \"symlinks\", \"mixed\",\n405:    for fx in [\"basic\", \"permissions\", \"sizes\"]:\n421:    for fx in [\"basic\", \"timestamps\", \"sizes\", \"extensions\", \"versions\", \"mixed\"]:\n432:    for fx in [\"basic\", \"timestamps\", \"sizes\"]:\n443:    for fx in [\"basic\", \"mixed\"]:\n451:    for fx in [\"basic\", \"many\", \"wide_names\", \"extensions\"]:\n459:    for fx in [\"basic\", \"many\"]:\n481:    for fx in [\"basic\", \"deep\", \"mixed\", \"symlinks\"]:\n527:    for fx in [\"basic\", \"mixed\", \"symlinks\"]:\n561:    for fx in [\"basic\", \"mixed\"]:\n567:    for fx in [\"basic\", \"mixed\", \"symlinks\", \"permissions\", \"special_files\"]:\n572:    for fx in [\"basic\", \"mixed\", \"permissions\"]:\n586:    for fx in [\"basic\", \"mixed\"]:\n607:    add(\"t8_override_f_then_l\", \"basic\", [\"-fl\"], 8)\n608:    add(\"t8_override_l_then_1\", \"basic\", [\"-l\", \"-1\"], 8)\n609:    add(\"t8_override_C_then_l\", \"basic\", [\"-C\", \"-l\"], 8)\n610:    add(\"t8_override_1_then_C\", \"basic\", [\"-1\", \"-C\"], 8)\n667:    1: \"tier1_basic\",\n713:        expected = normalize_output(stdout)\n715:        # Save expected output\n716:        exp_path = os.path.join(EXPECTED_DIR, f\"{name}.expected\")\n718:            f.write(expected)\n757:    create_examples()\n760:def create_examples():\n761:    \"\"\"Copy a small subset of fixtures + expected outputs to workspace/examples.\"\"\"\n762:    examples_dir = EXAMPLES_SRC\n763:    os.makedirs(os.path.join(examples_dir, \"expected\"), exist_ok=True)\n765:    # Copy basic fixture (only if this scope actually built it; some scopes —\n766:    # e.g. the performance tier — do not use the `basic` fixture at all).\n767:    src = os.path.join(FIXTURES_DIR, \"basic\")\n768:    dst = os.path.join(examples_dir, \"basic\")\n770:        print(\"  (no 'basic' fixture in scope; skipping workspace examples)\")\n776:    # Copy up to a handful of in-scope expected outputs for the basic fixture.\n778:    # if the basic fixture is not used by this scope, nothing is copied.\n780:    basic_expected = sorted(_glob.glob(os.path.join(EXPECTED_DIR, \"t*_basic_*.expected\")))\n781:    for src_f in basic_expected[:6]:\n782:        base = os.path.basename(src_f)[: -len(\".expected\")]\n783:        shutil.copy2(src_f, os.path.join(examples_dir, \"expected\", f\"{base}.txt\"))\n785:    print(f\"  Examples written to {examples_dir}\")\n","exit":0,"description":"Check what build_tests.py creates","truncated":false},"title":"Check what build_tests.py creates","time":{"start":1781082427137,"end":1781082427145}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_eb0c9097c001kqYFGykgAKzupP","sessionID":"ses_14f37e5c0ffewUVDEfJ2NQ59Gq","messageID":"msg_eb0c8fdeb001ILbll8rYYQTb31"}}
