aj  staff  16705 Jun 10 13:08 test.sh\n","exit":0,"description":"List tests and environment dirs","truncated":false},"title":"List tests and environment dirs","time":{"start":1781082366219,"end":1781082366231}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_eb0c81d8f001d9HY2RTBvO87Ra","sessionID":"ses_14f38057bffeIT5v3QDi2oCNBE","messageID":"msg_eb0c81339001ALfXUtTfbJcHEU"}}
