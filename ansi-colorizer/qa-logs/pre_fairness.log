{"type":"tool_use","timestamp":1781082981693,"sessionID":"ses_14f2f6a1dffe5tjqcH5PnHscaJ","part":{"type":"tool","tool":"read","callID":"toolu_019gYLkTvmyS4C4dxtBKAE5w","state":{"status":"completed","input":{"filePath":"/Users/dheeraj/Downloads/refactor/bespoke-labs-tasks-01/rust-ls-color-advanced/environment/build_tests.py"},"output":"<path>/Users/dheeraj/Downloads/refactor/bespoke-labs-tasks-01/rust-ls-color-advanced/environment/build_tests.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"\n3: Generate test fixtures and expected outputs for the rust-ls RL environment.\n4: \n5: Creates directory structures with controlled file metadata, runs the oracle\n6: GNU ls on each with various flag combinations, and saves expected outputs\n7: organized by difficulty tier.\n8: \"\"\"\n9: \n10: import json\n11: import os\n12: import shutil\n13: import stat\n14: import subprocess\n15: import sys\n16: import time\n17: \n18: ORACLE_LS = \"/oracle/ls\"\n19: FIXTURES_DIR = \"/app/fixtures\"\n20: TESTS_DIR = \"/app/tests\"\n21: EXPECTED_DIR = \"/expected\"\n22: EXAMPLES_SRC = \"/app/workspace/examples\"\n23: \n24: TIMEOUT = 60\n25: \n26: # ---------------------------------------------------------------------------\n27: # SCOPE: this is a scoped variant of the full rust-ls task. Only the tiers in\n28: # SCOPE_TIERS are curated, scored, and described in instruction.md. The oracle\n29: # (GNU ls) and verifier are otherwise identical to the parent task.\n30: # ---------------------------------------------------------------------------\n31: SCOPE_TIERS = {8}  # tier8_color_advanced\n32: \n33: # Fixed timestamps (all in the past so time display format is deterministic)\n34: TS = {\n35:     \"2000\": 947854200,   # 2000-01-14 10:30:00 UTC\n36:     \"2005\": 1119275100,  # 2005-06-20 14:45:00 UTC\n37:     \"2010\": 1268208900,  # 2010-03-10 08:15:00 UTC\n38:     \"2015\": 1448492400,  # 2015-11-25 22:00:00 UTC\n39:     \"2020\": 1593880200,  # 2020-07-04 16:30:00 UTC\n40: }\n41: \n42: # Standard LS_COLORS for color tests\n43: LS_COLORS_VAL = (\n44:     \"rs=0:di=01;34:ln=01;36:mh=00:pi=40;33:so=01;35:do=01;35:\"\n45:     \"bd=40;33;01:cd=40;33;01:or=40;31;01:mi=00:su=37;41:sg=30;43:\"\n46:     \"ca=00:tw=30;42:ow=34;42:st=37;44:ex=01;32\"\n47: )\n48: \n49: # Deterministic environment for oracle runs\n50: BASE_ENV = {\n51:     \"LC_ALL\": \"C\",\n52:     \"TZ\": \"UTC\",\n53:     \"COLUMNS\": \"80\",\n54:     \"TERM\": \"xterm-256color\",\n55:     \"PATH\": \"/usr/bin:/bin:/usr/sbin:/sbin\",\n56:     \"HOME\": \"/root\",\n57: }\n58: \n59: \n60: def make_env(**extra):\n61:     env = dict(BASE_ENV)\n62:     env.update(extra)\n63:     return env\n64: \n65: \n66: def create_file(path, content=\"\", size=None, mode=0o644, ts_key=\"2020\"):\n67:     with open(path, \"w\") as f:\n68:         if size is not None:\n69:             if size > 0:\n70:                 f.seek(size - 1)\n71:                 f.write(\"\\0\")\n72:         else:\n73:             f.write(content)\n74:     os.chmod(path, mode)\n75:     t = TS[ts_key]\n76:     os.utime(path, (t, t))\n77: \n78: \n79: def create_dir(path, mode=0o755, ts_key=\"2020\"):\n80:     os.makedirs(path, exist_ok=True)\n81:     os.chmod(path, mode)\n82:     t = TS[ts_key]\n83:     os.utime(path, (t, t))\n84: \n85: \n86: # ---------------------------------------------------------------------------\n87: # Fixture creation\n88: # ---------------------------------------------------------------------------\n89: \n90: def create_fixture_basic():\n91:     d = os.path.join(FIXTURES_DIR, \"basic\")\n92:     create_dir(d)\n93:     for name in [\"alpha.txt\", \"beta.txt\", \"gamma.txt\", \"delta.txt\", \"epsilon.txt\"]:\n94:         create_file(os.path.join(d, name), content=f\"content of {name}\\n\")\n95:     create_dir(os.path.join(d, \"docs\"))\n96:     create_dir(os.path.join(d, \"src\"))\n97:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n98: \n99: \n100: def create_fixture_dotfiles():\n101:     d = os.path.join(FIXTURES_DIR, \"dotfiles\")\n102:     create_dir(d)\n103:     create_file(os.path.join(d, \".hidden\"), content=\"hidden\\n\", ts_key=\"2020\")\n104:     create_file(os.path.join(d, \".bashrc\"), content=\"# bashrc\\n\", ts_key=\"2015\")\n105:     create_file(os.path.join(d, \".profile\"), content=\"# profile\\n\", ts_key=\"2010\")\n106:     create_file(os.path.join(d, \"visible.txt\"), content=\"visible\\n\", ts_key=\"2020\")\n107:     create_file(os.path.join(d, \"readme.md\"), content=\"# readme\\n\", ts_key=\"2020\")\n108:     create_dir(os.path.join(d, \".config\"), ts_key=\"2015\")\n109:     create_dir(os.path.join(d, \".local\"), ts_key=\"2015\")\n110:     create_dir(os.path.join(d, \"public\"))\n111:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n112: \n113: \n114: def create_fixture_symlinks():\n115:     d = os.path.join(FIXTURES_DIR, \"symlinks\")\n116:     create_dir(d)\n117:     create_file(os.path.join(d, \"target.txt\"), content=\"I am the target\\n\")\n118:     create_file(os.path.join(d, \"other.txt\"), content=\"other file\\n\", ts_key=\"2015\")\n119:     create_dir(os.path.join(d, \"subdir\"))\n120:     create_file(os.path.join(d, \"subdir\", \"inner.txt\"), content=\"inner\\n\")\n121:     os.symlink(\"target.txt\", os.path.join(d, \"link_to_file\"))\n122:     os.symlink(\"subdir\", os.path.join(d, \"link_to_dir\"))\n123:     os.symlink(\"nonexistent\", os.path.join(d, \"broken_link\"))\n124:     os.symlink(\"broken_link\", os.path.join(d, \"chain_broken\"))\n125:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n126: \n127: \n128: def create_fixture_permissions():\n129:     d = os.path.join(FIXTURES_DIR, \"permissions\")\n130:     create_dir(d)\n131:     create_file(os.path.join(d, \"regular.txt\"), mode=0o644)\n132:     create_file(os.path.join(d, \"executable.sh\"), content=\"#!/bin/sh\\n\", mode=0o755)\n133:     create_file(os.path.join(d, \"readonly.txt\"), mode=0o444)\n134:     create_file(os.path.join(d, \"writeonly.txt\"), mode=0o222)\n135:     create_file(os.path.join(d, \"allperms.txt\"), mode=0o777)\n136:     create_file(os.path.join(d, \"noperms.txt\"), mode=0o000)\n137:     create_file(os.path.join(d, \"setuid_bin\"), content=\"#!/bin/sh\\n\", mode=0o4755)\n138:     create_file(os.path.join(d, \"setgid_bin\"), content=\"#!/bin/sh\\n\", mode=0o2755)\n139:     create_file(os.path.join(d, \"setuid_noexec\"), mode=0o4644)\n140:     create_file(os.path.join(d, \"setgid_noexec\"), mode=0o2644)\n141:     create_dir(os.path.join(d, \"sticky_dir\"), mode=0o1777)\n142:     create_dir(os.path.join(d, \"normal_dir\"))\n143:     create_dir(os.path.join(d, \"sticky_restricted\"), mode=0o1755)\n144:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n145: \n146: \n147: def create_fixture_timestamps():\n148:     d = os.path.join(FIXTURES_DIR, \"timestamps\")\n149:     create_dir(d)\n150:     create_file(os.path.join(d, \"year2000.txt\"), content=\"old\\n\", ts_key=\"2000\")\n151:     create_file(os.path.join(d, \"year2005.txt\"), content=\"older\\n\", ts_key=\"2005\")\n152:     create_file(os.path.join(d, \"year2010.txt\"), content=\"mid\\n\", ts_key=\"2010\")\n153:     create_file(os.path.join(d, \"year2015.txt\"), content=\"newer\\n\", ts_key=\"2015\")\n154:     create_file(os.path.join(d, \"year2020.txt\"), content=\"newest\\n\", ts_key=\"2020\")\n155:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n156: \n157: \n158: def create_fixture_sizes():\n159:     d = os.path.join(FIXTURES_DIR, \"sizes\")\n160:     create_dir(d)\n161:     create_file(os.path.join(d, \"empty.txt\"), size=0)\n162:     create_file(os.path.join(d, \"tiny.txt\"), content=\"x\")\n163:     create_file(os.path.join(d, \"hundred.txt\"), content=\"x\" * 100)\n164:     create_file(os.path.join(d, \"onek.txt\"), size=1024)\n165:     create_file(os.path.join(d, \"tenk.txt\"), size=10240)\n166:     create_file(os.path.join(d, \"hundredk.txt\"), size=102400)\n167:     create_file(os.path.join(d, \"onem.txt\"), size=1048576)\n168:     create_file(os.path.join(d, \"fivem.txt\"), size=5242880)\n169:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n170: \n171: \n172: def create_fixture_special_names():\n173:     d = os.path.join(FIXTURES_DIR, \"special_names\")\n174:     create_dir(d)\n175:     create_file(os.path.join(d, \"normal.txt\"))\n176:     create_file(os.path.join(d, \"file with spaces.txt\"), content=\"spaces\\n\")\n177:     create_file(os.path.join(d, \"file\\twith\\ttab.txt\"), content=\"tabs\\n\")\n178:     create_file(os.path.join(d, \"file'with'quotes.txt\"), content=\"quotes\\n\")\n179:     create_file(os.path.join(d, 'file\"with\"dquotes.txt'), content=\"dquotes\\n\")\n180:     create_file(os.path.join(d, \"file\\\\with\\\\backslash.txt\"), content=\"bs\\n\")\n181:     create_file(os.path.join(d, \"ALLCAPS.TXT\"))\n182:     create_file(os.path.join(d, \"MiXeD.CaSe\"))\n183:     # Control character in filename\n184:     create_file(os.path.join(d, \"ctrl\\x01char.txt\"), content=\"ctrl\\n\")\n185:     create_file(os.path.join(d, \"newline\\nname.txt\"), content=\"nl\\n\")\n186:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n187: \n188: \n189: def create_fixture_extensions():\n190:     d = os.path.join(FIXTURES_DIR, \"extensions\")\n191:     create_dir(d)\n192:     for ext in [\"py\", \"js\", \"rs\", \"c\", \"h\", \"txt\", \"md\", \"html\", \"css\", \"json\"]:\n193:         create_file(os.path.join(d, f\"file.{ext}\"))\n194:     create_file(os.path.join(d, \"noext\"))\n195:     create_file(os.path.join(d, \".hidden_ext\"))\n196:     create_file(os.path.join(d, \"multi.tar.gz\"))\n197:     create_file(os.path.join(d, \"multi.backup.txt\"))\n198:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n199: \n200: \n201: def create_fixture_deep():\n202:     d = os.path.join(FIXTURES_DIR, \"deep\")\n203:     create_dir(d)\n204:     create_file(os.path.join(d, \"root_file.txt\"))\n205:     cur = d\n206:     for i in range(1, 6):\n207:         cur = os.path.join(cur, f\"level{i}\")\n208:         create_dir(cur)\n209:         create_file(os.path.join(cur, f\"file_l{i}.txt\"), content=f\"level {i}\\n\")\n210:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n211: \n212: \n213: def create_fixture_many():\n214:     \"\"\"50 files for column formatting tests.\"\"\"\n215:     d = os.path.join(FIXTURES_DIR, \"many\")\n216:     create_dir(d)\n217:     for i in range(1, 51):\n218:         name = f\"item_{i:03d}.txt\"\n219:         create_file(os.path.join(d, name))\n220:     create_dir(os.path.join(d, \"subdir_a\"))\n221:     create_dir(os.path.join(d, \"subdir_b\"))\n222:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n223: \n224: \n225: def create_fixture_mixed():\n226:     d = os.path.join(FIXTURES_DIR, \"mixed\")\n227:     create_dir(d)\n228:     create_file(os.path.join(d, \"regular.txt\"), content=\"hello\\n\", ts_key=\"2015\")\n229:     create_file(os.path.join(d, \".hidden\"), content=\"secret\\n\", ts_key=\"2010\")\n230:     create_file(os.path.join(d, \"exec.sh\"), content=\"#!/bin/sh\\n\", mode=0o755, ts_key=\"2020\")\n231:     create_file(os.path.join(d, \"big.dat\"), size=1048576, ts_key=\"2005\")\n232:     create_file(os.path.join(d, \"backup.txt~\"), content=\"old\\n\", ts_key=\"2000\")\n233:     create_dir(os.path.join(d, \"mydir\"), ts_key=\"2020\")\n234:     create_file(os.path.join(d, \"mydir\", \"child.txt\"), content=\"child\\n\")\n235:     os.symlink(\"regular.txt\", os.path.join(d, \"link.txt\"))\n236:     os.symlink(\"nonexistent\", os.path.join(d, \"dead_link\"))\n237:     os.mkfifo(os.path.join(d, \"mypipe\"))\n238:     os.chmod(os.path.join(d, \"mypipe\"), 0o644)\n239:     os.utime(os.path.join(d, \"mypipe\"), (TS[\"2020\"], TS[\"2020\"]))\n240:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n241: \n242: \n243: def create_fixture_empty():\n244:     d = os.path.join(FIXTURES_DIR, \"empty\")\n245:     create_dir(d)\n246:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n247: \n248: \n249: def create_fixture_special_files():\n250:     d = os.path.join(FIXTURES_DIR, \"special_files\")\n251:     create_dir(d)\n252:     create_file(os.path.join(d, \"regular.txt\"))\n253:     os.mkfifo(os.path.join(d, \"myfifo\"))\n254:     os.chmod(os.path.join(d, \"myfifo\"), 0o644)\n255:     os.utime(os.path.join(d, \"myfifo\"), (TS[\"2020\"], TS[\"2020\"]))\n256:     create_file(os.path.join(d, \"exec_file\"), mode=0o755)\n257:     create_dir(os.path.join(d, \"adir\"))\n258:     os.symlink(\"regular.txt\", os.path.join(d, \"a_symlink\"))\n259:     os.symlink(\"nonexistent\", os.path.join(d, \"broken_sym\"))\n260:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n261: \n262: \n263: def create_fixture_versions():\n264:     \"\"\"Files with version numbers for -v (version sort) testing.\"\"\"\n265:     d = os.path.join(FIXTURES_DIR, \"versions\")\n266:     create_dir(d)\n267:     for name in [\n268:         \"file1.txt\", \"file2.txt\", \"file10.txt\", \"file20.txt\", \"file3.txt\",\n269:         \"file100.txt\", \"file11.txt\", \"v1.0.txt\", \"v1.1.txt\", \"v1.10.txt\",\n270:         \"v1.2.txt\", \"v2.0.txt\", \"v0.9.txt\",\n271:         \"release-1\", \"release-2\", \"release-10\", \"release-3\",\n272:     ]:\n273:         create_file(os.path.join(d, name))\n274:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n275: \n276: \n277: def create_fixture_backups():\n278:     \"\"\"Files with backup suffixes for -B testing.\"\"\"\n279:     d = os.path.join(FIXTURES_DIR, \"backups\")\n280:     create_dir(d)\n281:     create_file(os.path.join(d, \"config.txt\"))\n282:     create_file(os.path.join(d, \"config.txt~\"))\n283:     create_file(os.path.join(d, \"data.json\"))\n284:     create_file(os.path.join(d, \"data.json~\"))\n285:     create_file(os.path.join(d, \"keep_me.txt\"))\n286:     create_file(os.path.join(d, \"notes~\"))\n287:     create_dir(os.path.join(d, \"subdir\"))\n288:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n289: \n290: \n291: def create_fixture_wide_names():\n292:     \"\"\"Files with varying name lengths for column alignment tests.\"\"\"\n293:     d = os.path.join(FIXTURES_DIR, \"wide_names\")\n294:     create_dir(d)\n295:     for name in [\"a\", \"bb\", \"ccc\", \"dddd\", \"eeeee\", \"ffffff\",\n296:                  \"a_very_long_filename_that_tests_wrapping.txt\",\n297:                  \"short\", \"medium_length_name.rs\", \"x\"]:\n298:         create_file(os.path.join(d, name))\n299:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n300: \n301: \n302: def create_fixture_multi_arg():\n303:     \"\"\"Separate files/dirs for testing multi-argument ls invocations.\"\"\"\n304:     d = os.path.join(FIXTURES_DIR, \"multi_arg\")\n305:     create_dir(d)\n306:     create_file(os.path.join(d, \"file_a.txt\"), content=\"aaa\\n\", ts_key=\"2010\")\n307:     create_file(os.path.join(d, \"file_b.txt\"), content=\"bbb\\n\", ts_key=\"2015\")\n308:     create_dir(os.path.join(d, \"dir_one\"), ts_key=\"2020\")\n309:     create_file(os.path.join(d, \"dir_one\", \"x.txt\"))\n310:     create_file(os.path.join(d, \"dir_one\", \"y.txt\"))\n311:     create_dir(os.path.join(d, \"dir_two\"), ts_key=\"2020\")\n312:     create_file(os.path.join(d, \"dir_two\", \"z.txt\"))\n313:     os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n314: \n315: \n316: def create_fixture_perf():\n317:     \"\"\"10,000 files for performance testing.\"\"\"\n318:     d = os.path.join(FIXTURES_DIR, \"perf_10k\")\n319:     create_dir(d)\n320:     t = TS[\"2020\"]\n321:     for i in range(10000):\n322:         path = os.path.join(d, f\"file_{i:05d}.dat\")\n323:         with open(path, \"w\") as f:\n324:             pass\n325:         os.chmod(path, 0o644)\n326:         os.utime(path, (t, t))\n327:     os.utime(d, (t, t))\n328: \n329: \n330: FIXTURE_BUILDERS = {\n331:     \"basic\": create_fixture_basic,\n332:     \"dotfiles\": create_fixture_dotfiles,\n333:     \"symlinks\": create_fixture_symlinks,\n334:     \"permissions\": create_fixture_permissions,\n335:     \"timestamps\": create_fixture_timestamps,\n336:     \"sizes\": create_fixture_sizes,\n337:     \"special_names\": create_fixture_special_names,\n338:     \"extensions\": create_fixture_extensions,\n339:     \"deep\": create_fixture_deep,\n340:     \"many\": create_fixture_many,\n341:     \"mixed\": create_fixture_mixed,\n342:     \"empty\": create_fixture_empty,\n343:     \"special_files\": create_fixture_special_files,\n344:     \"versions\": create_fixture_versions,\n345:     \"backups\": create_fixture_backups,\n346:     \"wide_names\": create_fixture_wide_names,\n347:     \"multi_arg\": create_fixture_multi_arg,\n348:     \"perf_10k\": create_fixture_perf,\n349: }\n350: \n351: \n352: def create_all_fixtures(needed=None):\n353:     \"\"\"Create only the fixtures referenced by the in-scope test cases.\n354: \n355:     `needed` is a set of fixture names; when None, every fixture is built\n356:     (parent-task behavior). Scoping out unused fixtures — especially the 10k\n357:     file `perf_10k` tree — keeps the Docker build fast for the smaller tiers.\n358:     \"\"\"\n359:     os.makedirs(FIXTURES_DIR, exist_ok=True)\n360:     names = needed if needed is not None else list(FIXTURE_BUILDERS)\n361:     for name in FIXTURE_BUILDERS:          # deterministic order\n362:         if name in names:\n363:             FIXTURE_BUILDERS[name]()\n364:     print(f\"Created fixtures {sorted(names)} in {FIXTURES_DIR}\")\n365: \n366: \n367: # ---------------------------------------------------------------------------\n368: # Test case definitions\n369: # ---------------------------------------------------------------------------\n370: \n371: def fixture_path(name):\n372:     return os.path.join(FIXTURES_DIR, name)\n373: \n374: \n375: def define_test_cases():\n376:     \"\"\"Return list of test case dicts: {name, fixture, flags, tier, env_extra, args}.\"\"\"\n377:     tests = []\n378: \n379:     def add(name, fixture, flags, tier, env_extra=None, args=None, timeout=10):\n380:         tests.append({\n381:             \"name\": name,\n382:             \"fixture\": fixture,\n383:             \"flags\": flags,\n384:             \"tier\": tier,\n385:             \"env_extra\": env_extra or {},\n386:             \"args\": args,\n387:             \"timeout\": timeout,\n388:         })\n389: \n390:     # ===== TIER 1: Basic listing =====\n391:     for fx in [\"basic\", \"dotfiles\", \"empty\", \"many\", \"mixed\"]:\n392:         add(f\"t1_{fx}_no_flags\", fx, [], 1)\n393:         add(f\"t1_{fx}_one_col\", fx, [\"-1\"], 1)\n394:         add(f\"t1_{fx}_all\", fx, [\"-a\"], 1)\n395:         add(f\"t1_{fx}_almost_all\", fx, [\"-A\"], 1)\n396:         add(f\"t1_{fx}_all_one\", fx, [\"-a\", \"-1\"], 1)\n397:         add(f\"t1_{fx}_A_one\", fx, [\"-A\", \"-1\"], 1)\n398: \n399:     # ===== TIER 2: Long format =====\n400:     for fx in [\"basic\", \"dotfiles\", \"permissions\", \"sizes\", \"symlinks\", \"mixed\",\n401:                \"special_files\", \"timestamps\"]:\n402:         add(f\"t2_{fx}_long\", fx, [\"-l\"], 2)\n403:         add(f\"t2_{fx}_long_all\", fx, [\"-la\"], 2)\n404: \n405:     for fx in [\"basic\", \"permissions\", \"sizes\"]:\n406:         add(f\"t2_{fx}_numeric\", fx, [\"-n\"], 2)\n407:         add(f\"t2_{fx}_no_owner\", fx, [\"-g\"], 2)\n408:         add(f\"t2_{fx}_no_group\", fx, [\"-o\"], 2)\n409:         add(f\"t2_{fx}_long_no_group\", fx, [\"-lG\"], 2)\n410:         add(f\"t2_{fx}_inode\", fx, [\"-i\"], 2)\n411:         add(f\"t2_{fx}_size_blocks\", fx, [\"-s\"], 2)\n412:         add(f\"t2_{fx}_long_inode\", fx, [\"-li\"], 2)\n413:         add(f\"t2_{fx}_long_size\", fx, [\"-ls\"], 2)\n414:         add(f\"t2_{fx}_long_author\", fx, [\"-l\", \"--author\"], 2)\n415:         add(f\"t2_{fx}_inode_long\", fx, [\"-il\"], 2)\n416: \n417:     add(\"t2_symlinks_long_deref\", \"symlinks\", [\"-lL\"], 2)\n418:     add(\"t2_mixed_long_A\", \"mixed\", [\"-lA\"], 2)\n419: \n420:     # ===== TIER 3: Sorting =====\n421:     for fx in [\"basic\", \"timestamps\", \"sizes\", \"extensions\", \"versions\", \"mixed\"]:\n422:         add(f\"t3_{fx}_sort_size\", fx, [\"-S\"], 3)\n423:         add(f\"t3_{fx}_sort_time\", fx, [\"-t\"], 3)\n424:         add(f\"t3_{fx}_reverse\", fx, [\"-r\"], 3)\n425:         add(f\"t3_{fx}_unsorted\", fx, [\"-U\"], 3)\n426:         add(f\"t3_{fx}_sort_ext\", fx, [\"-X\"], 3)\n427: \n428:     for fx in [\"versions\"]:\n429:         add(f\"t3_{fx}_version_sort\", fx, [\"-v\"], 3)\n430:         add(f\"t3_{fx}_version_sort_r\", fx, [\"-vr\"], 3)\n431: \n432:     for fx in [\"basic\", \"timestamps\", \"sizes\"]:\n433:         add(f\"t3_{fx}_size_reverse\", fx, [\"-Sr\"], 3)\n434:         add(f\"t3_{fx}_time_reverse\", fx, [\"-tr\"], 3)\n435:         add(f\"t3_{fx}_long_sort_size\", fx, [\"-lS\"], 3)\n436:         add(f\"t3_{fx}_long_sort_time\", fx, [\"-lt\"], 3)\n437:         add(f\"t3_{fx}_long_time_rev\", fx, [\"-ltr\"], 3)\n438:         add(f\"t3_{fx}_sort_word_size\", fx, [\"--sort=size\"], 3)\n439:         add(f\"t3_{fx}_sort_word_time\", fx, [\"--sort=time\"], 3)\n440:         add(f\"t3_{fx}_sort_word_none\", fx, [\"--sort=none\"], 3)\n441:         add(f\"t3_{fx}_nosort_f\", fx, [\"-f\"], 3)\n442: \n443:     for fx in [\"basic\", \"mixed\"]:\n444:         add(f\"t3_{fx}_group_dirs_first\", fx, [\"--group-directories-first\"], 3)\n445:         add(f\"t3_{fx}_group_dirs_first_l\", fx, [\"-l\", \"--group-directories-first\"], 3)\n446: \n447:     add(\"t3_extensions_sort_word_ext\", \"extensions\", [\"--sort=extension\"], 3)\n448:     add(\"t3_versions_sort_word_ver\", \"versions\", [\"--sort=version\"], 3)\n449: \n450:     # ===== TIER 4: Output formatting =====\n451:     for fx in [\"basic\", \"many\", \"wide_names\", \"extensions\"]:\n452:         add(f\"t4_{fx}_columns\", fx, [\"-C\"], 4)\n453:         add(f\"t4_{fx}_across\", fx, [\"-x\"], 4)\n454:         add(f\"t4_{fx}_commas\", fx, [\"-m\"], 4)\n455:         add(f\"t4_{fx}_col_w40\", fx, [\"-C\", \"-w\", \"40\"], 4)\n456:         add(f\"t4_{fx}_col_w120\", fx, [\"-C\", \"-w\", \"120\"], 4)\n457:         add(f\"t4_{fx}_across_w40\", fx, [\"-x\", \"-w\", \"40\"], 4)\n458: \n459:     for fx in [\"basic\", \"many\"]:\n460:         add(f\"t4_{fx}_format_across\", fx, [\"--format=across\"], 4)\n461:         add(f\"t4_{fx}_format_commas\", fx, [\"--format=commas\"], 4)\n462:         add(f\"t4_{fx}_format_long\", fx, [\"--format=long\"], 4)\n463:         add(f\"t4_{fx}_format_single\", fx, [\"--format=single-column\"], 4)\n464:         add(f\"t4_{fx}_format_vertical\", fx, [\"--format=vertical\"], 4)\n465:         add(f\"t4_{fx}_tabsize_4\", fx, [\"-C\", \"-T\", \"4\"], 4)\n466: \n467:     add(\"t4_wide_names_col_w60\", \"wide_names\", [\"-C\", \"-w\", \"60\"], 4)\n468:     add(\"t4_wide_names_commas_w40\", \"wide_names\", [\"-m\", \"-w\", \"40\"], 4)\n469: \n470:     # ===== TIER 5: Symlinks, recursion, directories =====\n471:     for fx in [\"symlinks\", \"mixed\"]:\n472:         add(f\"t5_{fx}_deref\", fx, [\"-L\"], 5)\n473:         add(f\"t5_{fx}_long_deref\", fx, [\"-lL\"], 5)\n474:         add(f\"t5_{fx}_deref_cmd\", fx, [\"-H\"], 5)\n475:         add(f\"t5_{fx}_classify\", fx, [\"-F\"], 5)\n476:         add(f\"t5_{fx}_file_type\", fx, [\"--file-type\"], 5)\n477:         add(f\"t5_{fx}_slash\", fx, [\"-p\"], 5)\n478:         add(f\"t5_{fx}_dir_self\", fx, [\"-d\"], 5)\n479:         add(f\"t5_{fx}_long_dir_self\", fx, [\"-ld\"], 5)\n480: \n481:     for fx in [\"basic\", \"deep\", \"mixed\", \"symlinks\"]:\n482:         add(f\"t5_{fx}_recursive\", fx, [\"-R\"], 5)\n483:         add(f\"t5_{fx}_recursive_long\", fx, [\"-Rl\"], 5)\n484:         add(f\"t5_{fx}_recursive_all\", fx, [\"-Ra\"], 5)\n485: \n486:     for fx in [\"special_files\"]:\n487:         add(f\"t5_{fx}_classify\", fx, [\"-F\"], 5)\n488:         add(f\"t5_{fx}_long_classify\", fx, [\"-lF\"], 5)\n489:         add(f\"t5_{fx}_file_type\", fx, [\"--file-type\"], 5)\n490:         add(f\"t5_{fx}_ind_none\", fx, [\"--indicator-style=none\"], 5)\n491:         add(f\"t5_{fx}_ind_slash\", fx, [\"--indicator-style=slash\"], 5)\n492:         add(f\"t5_{fx}_ind_file_type\", fx, [\"--indicator-style=file-type\"], 5)\n493:         add(f\"t5_{fx}_ind_classify\", fx, [\"--indicator-style=classify\"], 5)\n494: \n495:     # Multi-argument tests\n496:     add(\"t5_multi_files\", \"multi_arg\", [\"-1\"],  5,\n497:         args=[\"file_a.txt\", \"file_b.txt\"])\n498:     add(\"t5_multi_dirs\", \"multi_arg\", [\"-1\"], 5,\n499:         args=[\"dir_one\", \"dir_two\"])\n500:     add(\"t5_multi_mixed\", \"multi_arg\", [\"-1\"], 5,\n501:         args=[\"file_a.txt\", \"dir_one\"])\n502:     add(\"t5_multi_long\", \"multi_arg\", [\"-l\"], 5,\n503:         args=[\"file_a.txt\", \"dir_one\", \"dir_two\"])\n504:     add(\"t5_multi_recursive\", \"multi_arg\", [\"-R\"], 5,\n505:         args=[\"dir_one\", \"dir_two\"])\n506: \n507:     # ===== TIER 6: Quoting & escaping =====\n508:     for fx in [\"special_names\"]:\n509:         add(f\"t6_{fx}_default\", fx, [], 6)\n510:         add(f\"t6_{fx}_escape\", fx, [\"-b\"], 6)\n511:         add(f\"t6_{fx}_hide_ctrl\", fx, [\"-q\"], 6)\n512:         add(f\"t6_{fx}_quote_name\", fx, [\"-Q\"], 6)\n513:         add(f\"t6_{fx}_literal\", fx, [\"-N\"], 6)\n514:         add(f\"t6_{fx}_show_ctrl\", fx, [\"--show-control-chars\"], 6)\n515:         add(f\"t6_{fx}_qs_literal\", fx, [\"--quoting-style=literal\"], 6)\n516:         add(f\"t6_{fx}_qs_shell\", fx, [\"--quoting-style=shell\"], 6)\n517:         add(f\"t6_{fx}_qs_shell_always\", fx, [\"--quoting-style=shell-always\"], 6)\n518:         add(f\"t6_{fx}_qs_c\", fx, [\"--quoting-style=c\"], 6)\n519:         add(f\"t6_{fx}_qs_escape\", fx, [\"--quoting-style=escape\"], 6)\n520:         add(f\"t6_{fx}_qs_shell_esc\", fx, [\"--quoting-style=shell-escape\"], 6)\n521:         add(f\"t6_{fx}_qs_shell_esc_always\", fx, [\"--quoting-style=shell-escape-always\"], 6)\n522:         add(f\"t6_{fx}_long_escape\", fx, [\"-lb\"], 6)\n523:         add(f\"t6_{fx}_long_quote\", fx, [\"-lQ\"], 6)\n524:         add(f\"t6_{fx}_long_literal\", fx, [\"-lN\"], 6)\n525: \n526:     # Quoting on other fixtures too\n527:     for fx in [\"basic\", \"mixed\", \"symlinks\"]:\n528:         add(f\"t6_{fx}_escape\", fx, [\"-b\"], 6)\n529:         add(f\"t6_{fx}_quote_name\", fx, [\"-Q\"], 6)\n530:         add(f\"t6_{fx}_literal\", fx, [\"-N\"], 6)\n531:         add(f\"t6_{fx}_qs_c\", fx, [\"--quoting-style=c\"], 6)\n532:         add(f\"t6_{fx}_qs_shell\", fx, [\"--quoting-style=shell\"], 6)\n533: \n534:     # ===== TIER 7: Time & size formatting =====\n535:     for fx in [\"sizes\"]:\n536:         add(f\"t7_{fx}_human\", fx, [\"-lh\"], 7)\n537:         add(f\"t7_{fx}_si\", fx, [\"-l\", \"--si\"], 7)\n538:         add(f\"t7_{fx}_block_K\", fx, [\"-l\", \"--block-size=K\"], 7)\n539:         add(f\"t7_{fx}_block_M\", fx, [\"-l\", \"--block-size=M\"], 7)\n540:         add(f\"t7_{fx}_block_1\", fx, [\"-l\", \"--block-size=1\"], 7)\n541:         add(f\"t7_{fx}_block_1K\", fx, [\"-l\", \"--block-size=1K\"], 7)\n542:         add(f\"t7_{fx}_block_1M\", fx, [\"-l\", \"--block-size=1M\"], 7)\n543:         add(f\"t7_{fx}_human_size\", fx, [\"-sh\"], 7)\n544:         add(f\"t7_{fx}_kibi_size\", fx, [\"-sk\"], 7)\n545: \n546:     for fx in [\"timestamps\"]:\n547:         add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n548:         add(f\"t7_{fx}_ts_full_iso\", fx, [\"-l\", \"--time-style=full-iso\"], 7)\n549:         add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n550:         add(f\"t7_{fx}_ts_iso\", fx, [\"-l\", \"--time-style=iso\"], 7)\n551:         add(f\"t7_{fx}_ts_locale\", fx, [\"-l\", \"--time-style=locale\"], 7)\n552:         add(f\"t7_{fx}_ctime\", fx, [\"-lc\"], 7)\n553:         add(f\"t7_{fx}_atime\", fx, [\"-lu\"], 7)\n554:         add(f\"t7_{fx}_sort_ctime\", fx, [\"-ltc\"], 7)\n555:         add(f\"t7_{fx}_sort_atime\", fx, [\"-ltu\"], 7)\n556:         add(f\"t7_{fx}_time_word_atime\", fx, [\"-l\", \"--time=atime\"], 7)\n557:         add(f\"t7_{fx}_time_word_ctime\", fx, [\"-l\", \"--time=ctime\"], 7)\n558:         add(f\"t7_{fx}_ts_custom_fmt\", fx, [\"-l\", \"--time-style=+%Y-%m-%d\"], 7)\n559:         add(f\"t7_{fx}_ts_custom_fmt2\", fx, [\"-l\", \"--time-style=+%Y/%m/%d %H:%M\"], 7)\n560: \n561:     for fx in [\"basic\", \"mixed\"]:\n562:         add(f\"t7_{fx}_human_long\", fx, [\"-lh\"], 7)\n563:         add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n564:         add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n565: \n566:     # ===== TIER 8: Color, hide/ignore, advanced, combos =====\n567:     for fx in [\"basic\", \"mixed\", \"symlinks\", \"permissions\", \"special_files\"]:\n568:         add(f\"t8_{fx}_color_always\", fx, [\"--color=always\"], 8,\n569:             env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n570:         add(f\"t8_{fx}_color_never\", fx, [\"--color=never\"], 8)\n571: \n572:     for fx in [\"basic\", \"mixed\", \"permissions\"]:\n573:         add(f\"t8_{fx}_color_long\", fx, [\"-l\", \"--color=always\"], 8,\n574:             env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n575: \n576:     add(\"t8_symlinks_color_long\", \"symlinks\", [\"-l\", \"--color=always\"], 8,\n577:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n578:     add(\"t8_special_files_color_classify\", \"special_files\",\n579:         [\"-F\", \"--color=always\"], 8,\n580:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n581: \n582:     for fx in [\"backups\"]:\n583:         add(f\"t8_{fx}_ignore_backups\", fx, [\"-B\"], 8)\n584:         add(f\"t8_{fx}_ignore_backups_l\", fx, [\"-lB\"], 8)\n585: \n586:     for fx in [\"basic\", \"mixed\"]:\n587:         add(f\"t8_{fx}_ignore_pattern\", fx, [\"-I\", \"*.txt\"], 8)\n588:         add(f\"t8_{fx}_hide_pattern\", fx, [\"--hide=*.txt\"], 8)\n589:         add(f\"t8_{fx}_ignore_l\", fx, [\"-lI\", \"*.txt\"], 8)\n590: \n591:     add(\"t8_mixed_context\", \"mixed\", [\"-Z\"], 8)\n592:     add(\"t8_mixed_context_long\", \"mixed\", [\"-lZ\"], 8)\n593:     add(\"t8_permissions_context_long\", \"permissions\", [\"-lZ\"], 8)\n594: \n595:     # Multi-flag combos\n596:     add(\"t8_combo_laSr\", \"mixed\", [\"-laSr\"], 8)\n597:     add(\"t8_combo_latr\", \"timestamps\", [\"-latr\"], 8)\n598:     add(\"t8_combo_lhS\", \"sizes\", [\"-lhS\"], 8)\n599:     add(\"t8_combo_RlF\", \"deep\", [\"-RlF\"], 8)\n600:     add(\"t8_combo_lisg\", \"permissions\", [\"-lisg\"], 8)\n601:     add(\"t8_combo_color_classify_R\", \"mixed\",\n602:         [\"-RlF\", \"--color=always\"], 8,\n603:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n604:     add(\"t8_combo_quote_color\", \"special_names\",\n605:         [\"-Q\", \"--color=always\"], 8,\n606:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n607:     add(\"t8_override_f_then_l\", \"basic\", [\"-fl\"], 8)\n608:     add(\"t8_override_l_then_1\", \"basic\", [\"-l\", \"-1\"], 8)\n609:     add(\"t8_override_C_then_l\", \"basic\", [\"-C\", \"-l\"], 8)\n610:     add(\"t8_override_1_then_C\", \"basic\", [\"-1\", \"-C\"], 8)\n611: \n612:     # ===== TIER 9: Performance =====\n613:     add(\"t9_perf_no_flags\", \"perf_10k\", [], 9, timeout=60)\n614:     add(\"t9_perf_one_col\", \"perf_10k\", [\"-1\"], 9, timeout=60)\n615:     add(\"t9_perf_long\", \"perf_10k\", [\"-l\"], 9, timeout=60)\n616:     add(\"t9_perf_sort_size\", \"perf_10k\", [\"-S\"], 9, timeout=60)\n617:     add(\"t9_perf_columns\", \"perf_10k\", [\"-C\"], 9, timeout=60)\n618: \n619:     return tests\n620: \n621: \n622: # ---------------------------------------------------------------------------\n623: # Oracle runner\n624: # ---------------------------------------------------------------------------\n625: \n626: def run_oracle(fixture, flags, env_extra=None, args=None):\n627:     \"\"\"Run oracle ls and return (stdout, stderr, returncode).\"\"\"\n628:     env = make_env(**(env_extra or {}))\n629:     fx_path = fixture_path(fixture)\n630: \n631:     if args:\n632:         full_args = [os.path.join(fx_path, a) for a in args]\n633:     else:\n634:         full_args = [fx_path]\n635: \n636:     cmd = [ORACLE_LS] + flags + full_args\n637: \n638:     try:\n639:         result = subprocess.run(\n640:             cmd,\n641:             capture_output=True,\n642:             env=env,\n643:             timeout=TIMEOUT,\n644:         )\n645:         return result.stdout.decode(\"utf-8\", errors=\"replace\"), result.returncode\n646:     except subprocess.TimeoutExpired:\n647:         return None, -1\n648:     except Exception as e:\n649:         print(f\"  ERROR running oracle: {e}\", file=sys.stderr)\n650:         return None, -1\n651: \n652: \n653: def normalize_output(text):\n654:     \"\"\"Strip trailing whitespace from each line.\"\"\"\n655:     lines = text.split(\"\\n\")\n656:     cleaned = [l.rstrip() for l in lines]\n657:     while cleaned and cleaned[-1] == \"\":\n658:         cleaned.pop()\n659:     return \"\\n\".join(cleaned) + \"\\n\" if cleaned else \"\"\n660: \n661: \n662: # ---------------------------------------------------------------------------\n663: # Main\n664: # ---------------------------------------------------------------------------\n665: \n666: TIER_NAMES = {\n667:     1: \"tier1_basic\",\n668:     2: \"tier2_long_format\",\n669:     3: \"tier3_sorting\",\n670:     4: \"tier4_formatting\",\n671:     5: \"tier5_symlinks_recursion\",\n672:     6: \"tier6_quoting_escaping\",\n673:     7: \"tier7_time_size\",\n674:     8: \"tier8_color_advanced\",\n675:     9: \"tier9_performance\",\n676: }\n677: \n678: \n679: def main():\n680:     print(\"=== Defining test cases ===\")\n681:     test_cases = [tc for tc in define_test_cases() if tc[\"tier\"] in SCOPE_TIERS]\n682:     print(f\"  In-scope tiers: {sorted(SCOPE_TIERS)}\")\n683:     print(f\"  Total test cases: {len(test_cases)}\")\n684: \n685:     print(\"=== Creating fixtures ===\")\n686:     needed = {tc[\"fixture\"] for tc in test_cases}\n687:     create_all_fixtures(needed)\n688: \n689:     os.makedirs(TESTS_DIR, exist_ok=True)\n690:     os.makedirs(EXPECTED_DIR, exist_ok=True)\n691: \n692:     for tier_num in SCOPE_TIERS:\n693:         os.makedirs(os.path.join(TESTS_DIR, TIER_NAMES[tier_num]), exist_ok=True)\n694: \n695:     print(\"=== Running oracle on each test case ===\")\n696:     manifest = []\n697:     stats = {t: {\"total\": 0, \"ok\": 0, \"fail\": 0} for t in SCOPE_TIERS}\n698: \n699:     for tc in test_cases:\n700:         name = tc[\"name\"]\n701:         tier = tc[\"tier\"]\n702:         tier_name = TIER_NAMES[tier]\n703:         stats[tier][\"total\"] += 1\n704: \n705:         stdout, rc = run_oracle(tc[\"fixture\"], tc[\"flags\"],\n706:                                 tc.get(\"env_extra\"), tc.get(\"args\"))\n707: \n708:         if stdout is None:\n709:             print(f\"  SKIP {name} (oracle timeout/error)\")\n710:             stats[tier][\"fail\"] += 1\n711:             continue\n712: \n713:         expected = normalize_output(stdout)\n714: \n715:         # Save expected output\n716:         exp_path = os.path.join(EXPECTED_DIR, f\"{name}.expected\")\n717:         with open(exp_path, \"w\") as f:\n718:             f.write(expected)\n719: \n720:         # Save test definition (JSON with fixture, flags, args, env)\n721:         test_def = {\n722:             \"name\": name,\n723:             \"fixture\": tc[\"fixture\"],\n724:             \"flags\": tc[\"flags\"],\n725:             \"tier\": tier,\n726:             \"tier_name\": tier_name,\n727:             \"timeout\": tc.get(\"timeout\", 10),\n728:         }\n729:         if tc.get(\"env_extra\"):\n730:             test_def[\"env_extra\"] = tc[\"env_extra\"]\n731:         if tc.get(\"args\"):\n732:             test_def[\"args\"] = tc[\"args\"]\n733: \n734:         def_path = os.path.join(TESTS_DIR, tier_name, f\"{name}.json\")\n735:         with open(def_path, \"w\") as f:\n736:             json.dump(test_def, f, indent=2)\n737: \n738:         manifest.append(test_def)\n739:         stats[tier][\"ok\"] += 1\n740: \n741:     # Write manifest\n742:     with open(os.path.join(EXPECTED_DIR, \"manifest.json\"), \"w\") as f:\n743:         json.dump(manifest, f, indent=2)\n744: \n745:     # Summary\n746:     print(\"\\n=== Curation complete ===\")\n747:     total_ok = 0\n748:     total_all = 0\n749:     for tier_num in sorted(SCOPE_TIERS):\n750:         s = stats[tier_num]\n751:         print(f\"  {TIER_NAMES[tier_num]}: {s['ok']}/{s['total']} tests\")\n752:         total_ok += s[\"ok\"]\n753:         total_all += s[\"total\"]\n754:     print(f\"  TOTAL: {total_ok}/{total_all} tests\")\n755: \n756:     # Create example fixtures for the agent workspace\n757:     create_examples()\n758: \n759: \n760: def create_examples():\n761:     \"\"\"Copy a small subset of fixtures + expected outputs to workspace/examples.\"\"\"\n762:     examples_dir = EXAMPLES_SRC\n763:     os.makedirs(os.path.join(examples_dir, \"expected\"), exist_ok=True)\n764: \n765:     # Copy basic fixture (only if this scope actually built it; some scopes —\n766:     # e.g. the performance tier — do not use the `basic` fixture at all).\n767:     src = os.path.join(FIXTURES_DIR, \"basic\")\n768:     dst = os.path.join(examples_dir, \"basic\")\n769:     if not os.path.exists(src):\n770:         print(\"  (no 'basic' fixture in scope; skipping workspace examples)\")\n771:         return\n772:     if os.path.exists(dst):\n773:         shutil.rmtree(dst)\n774:     shutil.copytree(src, dst)\n775: \n776:     # Copy up to a handful of in-scope expected outputs for the basic fixture.\n777:     # Globbed (not hardcoded) so this works for whatever tier(s) are in scope;\n778:     # if the basic fixture is not used by this scope, nothing is copied.\n779:     import glob as _glob\n780:     basic_expected = sorted(_glob.glob(os.path.join(EXPECTED_DIR, \"t*_basic_*.expected\")))\n781:     for src_f in basic_expected[:6]:\n782:         base = os.path.basename(src_f)[: -len(\".expected\")]\n783:         shutil.copy2(src_f, os.path.join(examples_dir, \"expected\", f\"{base}.txt\"))\n784: \n785:     print(f\"  Examples written to {examples_dir}\")\n786: \n787: \n788: if __name__ == \"__main__\":\n789:     main()\n\n(End of file - total 789 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"\nGenerate test fixtures and expected outputs for the rust-ls RL environment.\n\nCreates directory structures with controlled file metadata, runs the oracle\nGNU ls on each with various flag combinations, and saves expected outputs\norganized by difficulty tier.\n\"\"\"\n\nimport json\nimport os\nimport shutil\nimport stat\nimport subprocess\nimport sys\nimport time\n\nORACLE_LS = \"/oracle/ls\"\nFIXTURES_DIR = \"/app/fixtures\"\nTESTS_DIR = \"/app/tests\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/dheeraj/Downloads/refactor/bespoke-labs-tasks-01/rust-ls-color-advanced/environment/build_tests.py","text":"#!/usr/bin/env python3\n\"\"\"\nGenerate test fixtures and expected outputs for the rust-ls RL environment.\n\nCreates directory structures with controlled file metadata, runs the oracle\nGNU ls on each with various flag combinations, and saves expected outputs\norganized by difficulty tier.\n\"\"\"\n\nimport json\nimport os\nimport shutil\nimport stat\nimport subprocess\nimport sys\nimport time\n\nORACLE_LS = \"/oracle/ls\"\nFIXTURES_DIR = \"/app/fixtures\"\nTESTS_DIR = \"/app/tests\"\nEXPECTED_DIR = \"/expected\"\nEXAMPLES_SRC = \"/app/workspace/examples\"\n\nTIMEOUT = 60\n\n# ---------------------------------------------------------------------------\n# SCOPE: this is a scoped variant of the full rust-ls task. Only the tiers in\n# SCOPE_TIERS are curated, scored, and described in instruction.md. The oracle\n# (GNU ls) and verifier are otherwise identical to the parent task.\n# ---------------------------------------------------------------------------\nSCOPE_TIERS = {8}  # tier8_color_advanced\n\n# Fixed timestamps (all in the past so time display format is deterministic)\nTS = {\n    \"2000\": 947854200,   # 2000-01-14 10:30:00 UTC\n    \"2005\": 1119275100,  # 2005-06-20 14:45:00 UTC\n    \"2010\": 1268208900,  # 2010-03-10 08:15:00 UTC\n    \"2015\": 1448492400,  # 2015-11-25 22:00:00 UTC\n    \"2020\": 1593880200,  # 2020-07-04 16:30:00 UTC\n}\n\n# Standard LS_COLORS for color tests\nLS_COLORS_VAL = (\n    \"rs=0:di=01;34:ln=01;36:mh=00:pi=40;33:so=01;35:do=01;35:\"\n    \"bd=40;33;01:cd=40;33;01:or=40;31;01:mi=00:su=37;41:sg=30;43:\"\n    \"ca=00:tw=30;42:ow=34;42:st=37;44:ex=01;32\"\n)\n\n# Deterministic environment for oracle runs\nBASE_ENV = {\n    \"LC_ALL\": \"C\",\n    \"TZ\": \"UTC\",\n    \"COLUMNS\": \"80\",\n    \"TERM\": \"xterm-256color\",\n    \"PATH\": \"/usr/bin:/bin:/usr/sbin:/sbin\",\n    \"HOME\": \"/root\",\n}\n\n\ndef make_env(**extra):\n    env = dict(BASE_ENV)\n    env.update(extra)\n    return env\n\n\ndef create_file(path, content=\"\", size=None, mode=0o644, ts_key=\"2020\"):\n    with open(path, \"w\") as f:\n        if size is not None:\n            if size > 0:\n                f.seek(size - 1)\n                f.write(\"\\0\")\n        else:\n            f.write(content)\n    os.chmod(path, mode)\n    t = TS[ts_key]\n    os.utime(path, (t, t))\n\n\ndef create_dir(path, mode=0o755, ts_key=\"2020\"):\n    os.makedirs(path, exist_ok=True)\n    os.chmod(path, mode)\n    t = TS[ts_key]\n    os.utime(path, (t, t))\n\n\n# ---------------------------------------------------------------------------\n# Fixture creation\n# ---------------------------------------------------------------------------\n\ndef create_fixture_basic():\n    d = os.path.join(FIXTURES_DIR, \"basic\")\n    create_dir(d)\n    for name in [\"alpha.txt\", \"beta.txt\", \"gamma.txt\", \"delta.txt\", \"epsilon.txt\"]:\n        create_file(os.path.join(d, name), content=f\"content of {name}\\n\")\n    create_dir(os.path.join(d, \"docs\"))\n    create_dir(os.path.join(d, \"src\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_dotfiles():\n    d = os.path.join(FIXTURES_DIR, \"dotfiles\")\n    create_dir(d)\n    create_file(os.path.join(d, \".hidden\"), content=\"hidden\\n\", ts_key=\"2020\")\n    create_file(os.path.join(d, \".bashrc\"), content=\"# bashrc\\n\", ts_key=\"2015\")\n    create_file(os.path.join(d, \".profile\"), content=\"# profile\\n\", ts_key=\"2010\")\n    create_file(os.path.join(d, \"visible.txt\"), content=\"visible\\n\", ts_key=\"2020\")\n    create_file(os.path.join(d, \"readme.md\"), content=\"# readme\\n\", ts_key=\"2020\")\n    create_dir(os.path.join(d, \".config\"), ts_key=\"2015\")\n    create_dir(os.path.join(d, \".local\"), ts_key=\"2015\")\n    create_dir(os.path.join(d, \"public\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_symlinks():\n    d = os.path.join(FIXTURES_DIR, \"symlinks\")\n    create_dir(d)\n    create_file(os.path.join(d, \"target.txt\"), content=\"I am the target\\n\")\n    create_file(os.path.join(d, \"other.txt\"), content=\"other file\\n\", ts_key=\"2015\")\n    create_dir(os.path.join(d, \"subdir\"))\n    create_file(os.path.join(d, \"subdir\", \"inner.txt\"), content=\"inner\\n\")\n    os.symlink(\"target.txt\", os.path.join(d, \"link_to_file\"))\n    os.symlink(\"subdir\", os.path.join(d, \"link_to_dir\"))\n    os.symlink(\"nonexistent\", os.path.join(d, \"broken_link\"))\n    os.symlink(\"broken_link\", os.path.join(d, \"chain_broken\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_permissions():\n    d = os.path.join(FIXTURES_DIR, \"permissions\")\n    create_dir(d)\n    create_file(os.path.join(d, \"regular.txt\"), mode=0o644)\n    create_file(os.path.join(d, \"executable.sh\"), content=\"#!/bin/sh\\n\", mode=0o755)\n    create_file(os.path.join(d, \"readonly.txt\"), mode=0o444)\n    create_file(os.path.join(d, \"writeonly.txt\"), mode=0o222)\n    create_file(os.path.join(d, \"allperms.txt\"), mode=0o777)\n    create_file(os.path.join(d, \"noperms.txt\"), mode=0o000)\n    create_file(os.path.join(d, \"setuid_bin\"), content=\"#!/bin/sh\\n\", mode=0o4755)\n    create_file(os.path.join(d, \"setgid_bin\"), content=\"#!/bin/sh\\n\", mode=0o2755)\n    create_file(os.path.join(d, \"setuid_noexec\"), mode=0o4644)\n    create_file(os.path.join(d, \"setgid_noexec\"), mode=0o2644)\n    create_dir(os.path.join(d, \"sticky_dir\"), mode=0o1777)\n    create_dir(os.path.join(d, \"normal_dir\"))\n    create_dir(os.path.join(d, \"sticky_restricted\"), mode=0o1755)\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_timestamps():\n    d = os.path.join(FIXTURES_DIR, \"timestamps\")\n    create_dir(d)\n    create_file(os.path.join(d, \"year2000.txt\"), content=\"old\\n\", ts_key=\"2000\")\n    create_file(os.path.join(d, \"year2005.txt\"), content=\"older\\n\", ts_key=\"2005\")\n    create_file(os.path.join(d, \"year2010.txt\"), content=\"mid\\n\", ts_key=\"2010\")\n    create_file(os.path.join(d, \"year2015.txt\"), content=\"newer\\n\", ts_key=\"2015\")\n    create_file(os.path.join(d, \"year2020.txt\"), content=\"newest\\n\", ts_key=\"2020\")\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_sizes():\n    d = os.path.join(FIXTURES_DIR, \"sizes\")\n    create_dir(d)\n    create_file(os.path.join(d, \"empty.txt\"), size=0)\n    create_file(os.path.join(d, \"tiny.txt\"), content=\"x\")\n    create_file(os.path.join(d, \"hundred.txt\"), content=\"x\" * 100)\n    create_file(os.path.join(d, \"onek.txt\"), size=1024)\n    create_file(os.path.join(d, \"tenk.txt\"), size=10240)\n    create_file(os.path.join(d, \"hundredk.txt\"), size=102400)\n    create_file(os.path.join(d, \"onem.txt\"), size=1048576)\n    create_file(os.path.join(d, \"fivem.txt\"), size=5242880)\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_special_names():\n    d = os.path.join(FIXTURES_DIR, \"special_names\")\n    create_dir(d)\n    create_file(os.path.join(d, \"normal.txt\"))\n    create_file(os.path.join(d, \"file with spaces.txt\"), content=\"spaces\\n\")\n    create_file(os.path.join(d, \"file\\twith\\ttab.txt\"), content=\"tabs\\n\")\n    create_file(os.path.join(d, \"file'with'quotes.txt\"), content=\"quotes\\n\")\n    create_file(os.path.join(d, 'file\"with\"dquotes.txt'), content=\"dquotes\\n\")\n    create_file(os.path.join(d, \"file\\\\with\\\\backslash.txt\"), content=\"bs\\n\")\n    create_file(os.path.join(d, \"ALLCAPS.TXT\"))\n    create_file(os.path.join(d, \"MiXeD.CaSe\"))\n    # Control character in filename\n    create_file(os.path.join(d, \"ctrl\\x01char.txt\"), content=\"ctrl\\n\")\n    create_file(os.path.join(d, \"newline\\nname.txt\"), content=\"nl\\n\")\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_extensions():\n    d = os.path.join(FIXTURES_DIR, \"extensions\")\n    create_dir(d)\n    for ext in [\"py\", \"js\", \"rs\", \"c\", \"h\", \"txt\", \"md\", \"html\", \"css\", \"json\"]:\n        create_file(os.path.join(d, f\"file.{ext}\"))\n    create_file(os.path.join(d, \"noext\"))\n    create_file(os.path.join(d, \".hidden_ext\"))\n    create_file(os.path.join(d, \"multi.tar.gz\"))\n    create_file(os.path.join(d, \"multi.backup.txt\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_deep():\n    d = os.path.join(FIXTURES_DIR, \"deep\")\n    create_dir(d)\n    create_file(os.path.join(d, \"root_file.txt\"))\n    cur = d\n    for i in range(1, 6):\n        cur = os.path.join(cur, f\"level{i}\")\n        create_dir(cur)\n        create_file(os.path.join(cur, f\"file_l{i}.txt\"), content=f\"level {i}\\n\")\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_many():\n    \"\"\"50 files for column formatting tests.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"many\")\n    create_dir(d)\n    for i in range(1, 51):\n        name = f\"item_{i:03d}.txt\"\n        create_file(os.path.join(d, name))\n    create_dir(os.path.join(d, \"subdir_a\"))\n    create_dir(os.path.join(d, \"subdir_b\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_mixed():\n    d = os.path.join(FIXTURES_DIR, \"mixed\")\n    create_dir(d)\n    create_file(os.path.join(d, \"regular.txt\"), content=\"hello\\n\", ts_key=\"2015\")\n    create_file(os.path.join(d, \".hidden\"), content=\"secret\\n\", ts_key=\"2010\")\n    create_file(os.path.join(d, \"exec.sh\"), content=\"#!/bin/sh\\n\", mode=0o755, ts_key=\"2020\")\n    create_file(os.path.join(d, \"big.dat\"), size=1048576, ts_key=\"2005\")\n    create_file(os.path.join(d, \"backup.txt~\"), content=\"old\\n\", ts_key=\"2000\")\n    create_dir(os.path.join(d, \"mydir\"), ts_key=\"2020\")\n    create_file(os.path.join(d, \"mydir\", \"child.txt\"), content=\"child\\n\")\n    os.symlink(\"regular.txt\", os.path.join(d, \"link.txt\"))\n    os.symlink(\"nonexistent\", os.path.join(d, \"dead_link\"))\n    os.mkfifo(os.path.join(d, \"mypipe\"))\n    os.chmod(os.path.join(d, \"mypipe\"), 0o644)\n    os.utime(os.path.join(d, \"mypipe\"), (TS[\"2020\"], TS[\"2020\"]))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_empty():\n    d = os.path.join(FIXTURES_DIR, \"empty\")\n    create_dir(d)\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_special_files():\n    d = os.path.join(FIXTURES_DIR, \"special_files\")\n    create_dir(d)\n    create_file(os.path.join(d, \"regular.txt\"))\n    os.mkfifo(os.path.join(d, \"myfifo\"))\n    os.chmod(os.path.join(d, \"myfifo\"), 0o644)\n    os.utime(os.path.join(d, \"myfifo\"), (TS[\"2020\"], TS[\"2020\"]))\n    create_file(os.path.join(d, \"exec_file\"), mode=0o755)\n    create_dir(os.path.join(d, \"adir\"))\n    os.symlink(\"regular.txt\", os.path.join(d, \"a_symlink\"))\n    os.symlink(\"nonexistent\", os.path.join(d, \"broken_sym\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_versions():\n    \"\"\"Files with version numbers for -v (version sort) testing.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"versions\")\n    create_dir(d)\n    for name in [\n        \"file1.txt\", \"file2.txt\", \"file10.txt\", \"file20.txt\", \"file3.txt\",\n        \"file100.txt\", \"file11.txt\", \"v1.0.txt\", \"v1.1.txt\", \"v1.10.txt\",\n        \"v1.2.txt\", \"v2.0.txt\", \"v0.9.txt\",\n        \"release-1\", \"release-2\", \"release-10\", \"release-3\",\n    ]:\n        create_file(os.path.join(d, name))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_backups():\n    \"\"\"Files with backup suffixes for -B testing.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"backups\")\n    create_dir(d)\n    create_file(os.path.join(d, \"config.txt\"))\n    create_file(os.path.join(d, \"config.txt~\"))\n    create_file(os.path.join(d, \"data.json\"))\n    create_file(os.path.join(d, \"data.json~\"))\n    create_file(os.path.join(d, \"keep_me.txt\"))\n    create_file(os.path.join(d, \"notes~\"))\n    create_dir(os.path.join(d, \"subdir\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_wide_names():\n    \"\"\"Files with varying name lengths for column alignment tests.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"wide_names\")\n    create_dir(d)\n    for name in [\"a\", \"bb\", \"ccc\", \"dddd\", \"eeeee\", \"ffffff\",\n                 \"a_very_long_filename_that_tests_wrapping.txt\",\n                 \"short\", \"medium_length_name.rs\", \"x\"]:\n        create_file(os.path.join(d, name))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_multi_arg():\n    \"\"\"Separate files/dirs for testing multi-argument ls invocations.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"multi_arg\")\n    create_dir(d)\n    create_file(os.path.join(d, \"file_a.txt\"), content=\"aaa\\n\", ts_key=\"2010\")\n    create_file(os.path.join(d, \"file_b.txt\"), content=\"bbb\\n\", ts_key=\"2015\")\n    create_dir(os.path.join(d, \"dir_one\"), ts_key=\"2020\")\n    create_file(os.path.join(d, \"dir_one\", \"x.txt\"))\n    create_file(os.path.join(d, \"dir_one\", \"y.txt\"))\n    create_dir(os.path.join(d, \"dir_two\"), ts_key=\"2020\")\n    create_file(os.path.join(d, \"dir_two\", \"z.txt\"))\n    os.utime(d, (TS[\"2020\"], TS[\"2020\"]))\n\n\ndef create_fixture_perf():\n    \"\"\"10,000 files for performance testing.\"\"\"\n    d = os.path.join(FIXTURES_DIR, \"perf_10k\")\n    create_dir(d)\n    t = TS[\"2020\"]\n    for i in range(10000):\n        path = os.path.join(d, f\"file_{i:05d}.dat\")\n        with open(path, \"w\") as f:\n            pass\n        os.chmod(path, 0o644)\n        os.utime(path, (t, t))\n    os.utime(d, (t, t))\n\n\nFIXTURE_BUILDERS = {\n    \"basic\": create_fixture_basic,\n    \"dotfiles\": create_fixture_dotfiles,\n    \"symlinks\": create_fixture_symlinks,\n    \"permissions\": create_fixture_permissions,\n    \"timestamps\": create_fixture_timestamps,\n    \"sizes\": create_fixture_sizes,\n    \"special_names\": create_fixture_special_names,\n    \"extensions\": create_fixture_extensions,\n    \"deep\": create_fixture_deep,\n    \"many\": create_fixture_many,\n    \"mixed\": create_fixture_mixed,\n    \"empty\": create_fixture_empty,\n    \"special_files\": create_fixture_special_files,\n    \"versions\": create_fixture_versions,\n    \"backups\": create_fixture_backups,\n    \"wide_names\": create_fixture_wide_names,\n    \"multi_arg\": create_fixture_multi_arg,\n    \"perf_10k\": create_fixture_perf,\n}\n\n\ndef create_all_fixtures(needed=None):\n    \"\"\"Create only the fixtures referenced by the in-scope test cases.\n\n    `needed` is a set of fixture names; when None, every fixture is built\n    (parent-task behavior). Scoping out unused fixtures — especially the 10k\n    file `perf_10k` tree — keeps the Docker build fast for the smaller tiers.\n    \"\"\"\n    os.makedirs(FIXTURES_DIR, exist_ok=True)\n    names = needed if needed is not None else list(FIXTURE_BUILDERS)\n    for name in FIXTURE_BUILDERS:          # deterministic order\n        if name in names:\n            FIXTURE_BUILDERS[name]()\n    print(f\"Created fixtures {sorted(names)} in {FIXTURES_DIR}\")\n\n\n# ---------------------------------------------------------------------------\n# Test case definitions\n# ---------------------------------------------------------------------------\n\ndef fixture_path(name):\n    return os.path.join(FIXTURES_DIR, name)\n\n\ndef define_test_cases():\n    \"\"\"Return list of test case dicts: {name, fixture, flags, tier, env_extra, args}.\"\"\"\n    tests = []\n\n    def add(name, fixture, flags, tier, env_extra=None, args=None, timeout=10):\n        tests.append({\n            \"name\": name,\n            \"fixture\": fixture,\n            \"flags\": flags,\n            \"tier\": tier,\n            \"env_extra\": env_extra or {},\n            \"args\": args,\n            \"timeout\": timeout,\n        })\n\n    # ===== TIER 1: Basic listing =====\n    for fx in [\"basic\", \"dotfiles\", \"empty\", \"many\", \"mixed\"]:\n        add(f\"t1_{fx}_no_flags\", fx, [], 1)\n        add(f\"t1_{fx}_one_col\", fx, [\"-1\"], 1)\n        add(f\"t1_{fx}_all\", fx, [\"-a\"], 1)\n        add(f\"t1_{fx}_almost_all\", fx, [\"-A\"], 1)\n        add(f\"t1_{fx}_all_one\", fx, [\"-a\", \"-1\"], 1)\n        add(f\"t1_{fx}_A_one\", fx, [\"-A\", \"-1\"], 1)\n\n    # ===== TIER 2: Long format =====\n    for fx in [\"basic\", \"dotfiles\", \"permissions\", \"sizes\", \"symlinks\", \"mixed\",\n               \"special_files\", \"timestamps\"]:\n        add(f\"t2_{fx}_long\", fx, [\"-l\"], 2)\n        add(f\"t2_{fx}_long_all\", fx, [\"-la\"], 2)\n\n    for fx in [\"basic\", \"permissions\", \"sizes\"]:\n        add(f\"t2_{fx}_numeric\", fx, [\"-n\"], 2)\n        add(f\"t2_{fx}_no_owner\", fx, [\"-g\"], 2)\n        add(f\"t2_{fx}_no_group\", fx, [\"-o\"], 2)\n        add(f\"t2_{fx}_long_no_group\", fx, [\"-lG\"], 2)\n        add(f\"t2_{fx}_inode\", fx, [\"-i\"], 2)\n        add(f\"t2_{fx}_size_blocks\", fx, [\"-s\"], 2)\n        add(f\"t2_{fx}_long_inode\", fx, [\"-li\"], 2)\n        add(f\"t2_{fx}_long_size\", fx, [\"-ls\"], 2)\n        add(f\"t2_{fx}_long_author\", fx, [\"-l\", \"--author\"], 2)\n        add(f\"t2_{fx}_inode_long\", fx, [\"-il\"], 2)\n\n    add(\"t2_symlinks_long_deref\", \"symlinks\", [\"-lL\"], 2)\n    add(\"t2_mixed_long_A\", \"mixed\", [\"-lA\"], 2)\n\n    # ===== TIER 3: Sorting =====\n    for fx in [\"basic\", \"timestamps\", \"sizes\", \"extensions\", \"versions\", \"mixed\"]:\n        add(f\"t3_{fx}_sort_size\", fx, [\"-S\"], 3)\n        add(f\"t3_{fx}_sort_time\", fx, [\"-t\"], 3)\n        add(f\"t3_{fx}_reverse\", fx, [\"-r\"], 3)\n        add(f\"t3_{fx}_unsorted\", fx, [\"-U\"], 3)\n        add(f\"t3_{fx}_sort_ext\", fx, [\"-X\"], 3)\n\n    for fx in [\"versions\"]:\n        add(f\"t3_{fx}_version_sort\", fx, [\"-v\"], 3)\n        add(f\"t3_{fx}_version_sort_r\", fx, [\"-vr\"], 3)\n\n    for fx in [\"basic\", \"timestamps\", \"sizes\"]:\n        add(f\"t3_{fx}_size_reverse\", fx, [\"-Sr\"], 3)\n        add(f\"t3_{fx}_time_reverse\", fx, [\"-tr\"], 3)\n        add(f\"t3_{fx}_long_sort_size\", fx, [\"-lS\"], 3)\n        add(f\"t3_{fx}_long_sort_time\", fx, [\"-lt\"], 3)\n        add(f\"t3_{fx}_long_time_rev\", fx, [\"-ltr\"], 3)\n        add(f\"t3_{fx}_sort_word_size\", fx, [\"--sort=size\"], 3)\n        add(f\"t3_{fx}_sort_word_time\", fx, [\"--sort=time\"], 3)\n        add(f\"t3_{fx}_sort_word_none\", fx, [\"--sort=none\"], 3)\n        add(f\"t3_{fx}_nosort_f\", fx, [\"-f\"], 3)\n\n    for fx in [\"basic\", \"mixed\"]:\n        add(f\"t3_{fx}_group_dirs_first\", fx, [\"--group-directories-first\"], 3)\n        add(f\"t3_{fx}_group_dirs_first_l\", fx, [\"-l\", \"--group-directories-first\"], 3)\n\n    add(\"t3_extensions_sort_word_ext\", \"extensions\", [\"--sort=extension\"], 3)\n    add(\"t3_versions_sort_word_ver\", \"versions\", [\"--sort=version\"], 3)\n\n    # ===== TIER 4: Output formatting =====\n    for fx in [\"basic\", \"many\", \"wide_names\", \"extensions\"]:\n        add(f\"t4_{fx}_columns\", fx, [\"-C\"], 4)\n        add(f\"t4_{fx}_across\", fx, [\"-x\"], 4)\n        add(f\"t4_{fx}_commas\", fx, [\"-m\"], 4)\n        add(f\"t4_{fx}_col_w40\", fx, [\"-C\", \"-w\", \"40\"], 4)\n        add(f\"t4_{fx}_col_w120\", fx, [\"-C\", \"-w\", \"120\"], 4)\n        add(f\"t4_{fx}_across_w40\", fx, [\"-x\", \"-w\", \"40\"], 4)\n\n    for fx in [\"basic\", \"many\"]:\n        add(f\"t4_{fx}_format_across\", fx, [\"--format=across\"], 4)\n        add(f\"t4_{fx}_format_commas\", fx, [\"--format=commas\"], 4)\n        add(f\"t4_{fx}_format_long\", fx, [\"--format=long\"], 4)\n        add(f\"t4_{fx}_format_single\", fx, [\"--format=single-column\"], 4)\n        add(f\"t4_{fx}_format_vertical\", fx, [\"--format=vertical\"], 4)\n        add(f\"t4_{fx}_tabsize_4\", fx, [\"-C\", \"-T\", \"4\"], 4)\n\n    add(\"t4_wide_names_col_w60\", \"wide_names\", [\"-C\", \"-w\", \"60\"], 4)\n    add(\"t4_wide_names_commas_w40\", \"wide_names\", [\"-m\", \"-w\", \"40\"], 4)\n\n    # ===== TIER 5: Symlinks, recursion, directories =====\n    for fx in [\"symlinks\", \"mixed\"]:\n        add(f\"t5_{fx}_deref\", fx, [\"-L\"], 5)\n        add(f\"t5_{fx}_long_deref\", fx, [\"-lL\"], 5)\n        add(f\"t5_{fx}_deref_cmd\", fx, [\"-H\"], 5)\n        add(f\"t5_{fx}_classify\", fx, [\"-F\"], 5)\n        add(f\"t5_{fx}_file_type\", fx, [\"--file-type\"], 5)\n        add(f\"t5_{fx}_slash\", fx, [\"-p\"], 5)\n        add(f\"t5_{fx}_dir_self\", fx, [\"-d\"], 5)\n        add(f\"t5_{fx}_long_dir_self\", fx, [\"-ld\"], 5)\n\n    for fx in [\"basic\", \"deep\", \"mixed\", \"symlinks\"]:\n        add(f\"t5_{fx}_recursive\", fx, [\"-R\"], 5)\n        add(f\"t5_{fx}_recursive_long\", fx, [\"-Rl\"], 5)\n        add(f\"t5_{fx}_recursive_all\", fx, [\"-Ra\"], 5)\n\n    for fx in [\"special_files\"]:\n        add(f\"t5_{fx}_classify\", fx, [\"-F\"], 5)\n        add(f\"t5_{fx}_long_classify\", fx, [\"-lF\"], 5)\n        add(f\"t5_{fx}_file_type\", fx, [\"--file-type\"], 5)\n        add(f\"t5_{fx}_ind_none\", fx, [\"--indicator-style=none\"], 5)\n        add(f\"t5_{fx}_ind_slash\", fx, [\"--indicator-style=slash\"], 5)\n        add(f\"t5_{fx}_ind_file_type\", fx, [\"--indicator-style=file-type\"], 5)\n        add(f\"t5_{fx}_ind_classify\", fx, [\"--indicator-style=classify\"], 5)\n\n    # Multi-argument tests\n    add(\"t5_multi_files\", \"multi_arg\", [\"-1\"],  5,\n        args=[\"file_a.txt\", \"file_b.txt\"])\n    add(\"t5_multi_dirs\", \"multi_arg\", [\"-1\"], 5,\n        args=[\"dir_one\", \"dir_two\"])\n    add(\"t5_multi_mixed\", \"multi_arg\", [\"-1\"], 5,\n        args=[\"file_a.txt\", \"dir_one\"])\n    add(\"t5_multi_long\", \"multi_arg\", [\"-l\"], 5,\n        args=[\"file_a.txt\", \"dir_one\", \"dir_two\"])\n    add(\"t5_multi_recursive\", \"multi_arg\", [\"-R\"], 5,\n        args=[\"dir_one\", \"dir_two\"])\n\n    # ===== TIER 6: Quoting & escaping =====\n    for fx in [\"special_names\"]:\n        add(f\"t6_{fx}_default\", fx, [], 6)\n        add(f\"t6_{fx}_escape\", fx, [\"-b\"], 6)\n        add(f\"t6_{fx}_hide_ctrl\", fx, [\"-q\"], 6)\n        add(f\"t6_{fx}_quote_name\", fx, [\"-Q\"], 6)\n        add(f\"t6_{fx}_literal\", fx, [\"-N\"], 6)\n        add(f\"t6_{fx}_show_ctrl\", fx, [\"--show-control-chars\"], 6)\n        add(f\"t6_{fx}_qs_literal\", fx, [\"--quoting-style=literal\"], 6)\n        add(f\"t6_{fx}_qs_shell\", fx, [\"--quoting-style=shell\"], 6)\n        add(f\"t6_{fx}_qs_shell_always\", fx, [\"--quoting-style=shell-always\"], 6)\n        add(f\"t6_{fx}_qs_c\", fx, [\"--quoting-style=c\"], 6)\n        add(f\"t6_{fx}_qs_escape\", fx, [\"--quoting-style=escape\"], 6)\n        add(f\"t6_{fx}_qs_shell_esc\", fx, [\"--quoting-style=shell-escape\"], 6)\n        add(f\"t6_{fx}_qs_shell_esc_always\", fx, [\"--quoting-style=shell-escape-always\"], 6)\n        add(f\"t6_{fx}_long_escape\", fx, [\"-lb\"], 6)\n        add(f\"t6_{fx}_long_quote\", fx, [\"-lQ\"], 6)\n        add(f\"t6_{fx}_long_literal\", fx, [\"-lN\"], 6)\n\n    # Quoting on other fixtures too\n    for fx in [\"basic\", \"mixed\", \"symlinks\"]:\n        add(f\"t6_{fx}_escape\", fx, [\"-b\"], 6)\n        add(f\"t6_{fx}_quote_name\", fx, [\"-Q\"], 6)\n        add(f\"t6_{fx}_literal\", fx, [\"-N\"], 6)\n        add(f\"t6_{fx}_qs_c\", fx, [\"--quoting-style=c\"], 6)\n        add(f\"t6_{fx}_qs_shell\", fx, [\"--quoting-style=shell\"], 6)\n\n    # ===== TIER 7: Time & size formatting =====\n    for fx in [\"sizes\"]:\n        add(f\"t7_{fx}_human\", fx, [\"-lh\"], 7)\n        add(f\"t7_{fx}_si\", fx, [\"-l\", \"--si\"], 7)\n        add(f\"t7_{fx}_block_K\", fx, [\"-l\", \"--block-size=K\"], 7)\n        add(f\"t7_{fx}_block_M\", fx, [\"-l\", \"--block-size=M\"], 7)\n        add(f\"t7_{fx}_block_1\", fx, [\"-l\", \"--block-size=1\"], 7)\n        add(f\"t7_{fx}_block_1K\", fx, [\"-l\", \"--block-size=1K\"], 7)\n        add(f\"t7_{fx}_block_1M\", fx, [\"-l\", \"--block-size=1M\"], 7)\n        add(f\"t7_{fx}_human_size\", fx, [\"-sh\"], 7)\n        add(f\"t7_{fx}_kibi_size\", fx, [\"-sk\"], 7)\n\n    for fx in [\"timestamps\"]:\n        add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n        add(f\"t7_{fx}_ts_full_iso\", fx, [\"-l\", \"--time-style=full-iso\"], 7)\n        add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n        add(f\"t7_{fx}_ts_iso\", fx, [\"-l\", \"--time-style=iso\"], 7)\n        add(f\"t7_{fx}_ts_locale\", fx, [\"-l\", \"--time-style=locale\"], 7)\n        add(f\"t7_{fx}_ctime\", fx, [\"-lc\"], 7)\n        add(f\"t7_{fx}_atime\", fx, [\"-lu\"], 7)\n        add(f\"t7_{fx}_sort_ctime\", fx, [\"-ltc\"], 7)\n        add(f\"t7_{fx}_sort_atime\", fx, [\"-ltu\"], 7)\n        add(f\"t7_{fx}_time_word_atime\", fx, [\"-l\", \"--time=atime\"], 7)\n        add(f\"t7_{fx}_time_word_ctime\", fx, [\"-l\", \"--time=ctime\"], 7)\n        add(f\"t7_{fx}_ts_custom_fmt\", fx, [\"-l\", \"--time-style=+%Y-%m-%d\"], 7)\n        add(f\"t7_{fx}_ts_custom_fmt2\", fx, [\"-l\", \"--time-style=+%Y/%m/%d %H:%M\"], 7)\n\n    for fx in [\"basic\", \"mixed\"]:\n        add(f\"t7_{fx}_human_long\", fx, [\"-lh\"], 7)\n        add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n        add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n\n    # ===== TIER 8: Color, hide/ignore, advanced, combos =====\n    for fx in [\"basic\", \"mixed\", \"symlinks\", \"permissions\", \"special_files\"]:\n        add(f\"t8_{fx}_color_always\", fx, [\"--color=always\"], 8,\n            env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n        add(f\"t8_{fx}_color_never\", fx, [\"--color=never\"], 8)\n\n    for fx in [\"basic\", \"mixed\", \"permissions\"]:\n        add(f\"t8_{fx}_color_long\", fx, [\"-l\", \"--color=always\"], 8,\n            env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n\n    add(\"t8_symlinks_color_long\", \"symlinks\", [\"-l\", \"--color=always\"], 8,\n        env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n    add(\"t8_special_files_color_classify\", \"special_files\",\n        [\"-F\", \"--color=always\"], 8,\n        env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n\n    for fx in [\"backups\"]:\n        add(f\"t8_{fx}_ignore_backups\", fx, [\"-B\"], 8)\n        add(f\"t8_{fx}_ignore_backups_l\", fx, [\"-lB\"], 8)\n\n    for fx in [\"basic\", \"mixed\"]:\n        add(f\"t8_{fx}_ignore_pattern\", fx, [\"-I\", \"*.txt\"], 8)\n        add(f\"t8_{fx}_hide_pattern\", fx, [\"--hide=*.txt\"], 8)\n        add(f\"t8_{fx}_ignore_l\", fx, [\"-lI\", \"*.txt\"], 8)\n\n    add(\"t8_mixed_context\", \"mixed\", [\"-Z\"], 8)\n    add(\"t8_mixed_context_long\", \"mixed\", [\"-lZ\"], 8)\n    add(\"t8_permissions_context_long\", \"permissions\", [\"-lZ\"], 8)\n\n    # Multi-flag combos\n    add(\"t8_combo_laSr\", \"mixed\", [\"-laSr\"], 8)\n    add(\"t8_combo_latr\", \"timestamps\", [\"-latr\"], 8)\n    add(\"t8_combo_lhS\", \"sizes\", [\"-lhS\"], 8)\n    add(\"t8_combo_RlF\", \"deep\", [\"-RlF\"], 8)\n    add(\"t8_combo_lisg\", \"permissions\", [\"-lisg\"], 8)\n    add(\"t8_combo_color_classify_R\", \"mixed\",\n        [\"-RlF\", \"--color=always\"], 8,\n        env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n    add(\"t8_combo_quote_color\", \"special_names\",\n        [\"-Q\", \"--color=always\"], 8,\n        env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n    add(\"t8_override_f_then_l\", \"basic\", [\"-fl\"], 8)\n    add(\"t8_override_l_then_1\", \"basic\", [\"-l\", \"-1\"], 8)\n    add(\"t8_override_C_then_l\", \"basic\", [\"-C\", \"-l\"], 8)\n    add(\"t8_override_1_then_C\", \"basic\", [\"-1\", \"-C\"], 8)\n\n    # ===== TIER 9: Performance =====\n    add(\"t9_perf_no_flags\", \"perf_10k\", [], 9, timeout=60)\n    add(\"t9_perf_one_col\", \"perf_10k\", [\"-1\"], 9, timeout=60)\n    add(\"t9_perf_long\", \"perf_10k\", [\"-l\"], 9, timeout=60)\n    add(\"t9_perf_sort_size\", \"perf_10k\", [\"-S\"], 9, timeout=60)\n    add(\"t9_perf_columns\", \"perf_10k\", [\"-C\"], 9, timeout=60)\n\n    return tests\n\n\n# ---------------------------------------------------------------------------\n# Oracle runner\n# ---------------------------------------------------------------------------\n\ndef run_oracle(fixture, flags, env_extra=None, args=None):\n    \"\"\"Run oracle ls and return (stdout, stderr, returncode).\"\"\"\n    env = make_env(**(env_extra or {}))\n    fx_path = fixture_path(fixture)\n\n    if args:\n        full_args = [os.path.join(fx_path, a) for a in args]\n    else:\n        full_args = [fx_path]\n\n    cmd = [ORACLE_LS] + flags + full_args\n\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            env=env,\n            timeout=TIMEOUT,\n        )\n        return result.stdout.decode(\"utf-8\", errors=\"replace\"), result.returncode\n    except subprocess.TimeoutExpired:\n        return None, -1\n    except Exception as e:\n        print(f\"  ERROR running oracle: {e}\", file=sys.stderr)\n        return None, -1\n\n\ndef normalize_output(text):\n    \"\"\"Strip trailing whitespace from each line.\"\"\"\n    lines = text.split(\"\\n\")\n    cleaned = [l.rstrip() for l in lines]\n    while cleaned and cleaned[-1] == \"\":\n        cleaned.pop()\n    return \"\\n\".join(cleaned) + \"\\n\" if cleaned else \"\"\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\n\nTIER_NAMES = {\n    1: \"tier1_basic\",\n    2: \"tier2_long_format\",\n    3: \"tier3_sorting\",\n    4: \"tier4_formatting\",\n    5: \"tier5_symlinks_recursion\",\n    6: \"tier6_quoting_escaping\",\n    7: \"tier7_time_size\",\n    8: \"tier8_color_advanced\",\n    9: \"tier9_performance\",\n}\n\n\ndef main():\n    print(\"=== Defining test cases ===\")\n    test_cases = [tc for tc in define_test_cases() if tc[\"tier\"] in SCOPE_TIERS]\n    print(f\"  In-scope tiers: {sorted(SCOPE_TIERS)}\")\n    print(f\"  Total test cases: {len(test_cases)}\")\n\n    print(\"=== Creating fixtures ===\")\n    needed = {tc[\"fixture\"] for tc in test_cases}\n    create_all_fixtures(needed)\n\n    os.makedirs(TESTS_DIR, exist_ok=True)\n    os.makedirs(EXPECTED_DIR, exist_ok=True)\n\n    for tier_num in SCOPE_TIERS:\n        os.makedirs(os.path.join(TESTS_DIR, TIER_NAMES[tier_num]), exist_ok=True)\n\n    print(\"=== Running oracle on each test case ===\")\n    manifest = []\n    stats = {t: {\"total\": 0, \"ok\": 0, \"fail\": 0} for t in SCOPE_TIERS}\n\n    for tc in test_cases:\n        name = tc[\"name\"]\n        tier = tc[\"tier\"]\n        tier_name = TIER_NAMES[tier]\n        stats[tier][\"total\"] += 1\n\n        stdout, rc = run_oracle(tc[\"fixture\"], tc[\"flags\"],\n                                tc.get(\"env_extra\"), tc.get(\"args\"))\n\n        if stdout is None:\n            print(f\"  SKIP {name} (oracle timeout/error)\")\n            stats[tier][\"fail\"] += 1\n            continue\n\n        expected = normalize_output(stdout)\n\n        # Save expected output\n        exp_path = os.path.join(EXPECTED_DIR, f\"{name}.expected\")\n        with open(exp_path, \"w\") as f:\n            f.write(expected)\n\n        # Save test definition (JSON with fixture, flags, args, env)\n        test_def = {\n            \"name\": name,\n            \"fixture\": tc[\"fixture\"],\n            \"flags\": tc[\"flags\"],\n            \"tier\": tier,\n            \"tier_name\": tier_name,\n            \"timeout\": tc.get(\"timeout\", 10),\n        }\n        if tc.get(\"env_extra\"):\n            test_def[\"env_extra\"] = tc[\"env_extra\"]\n        if tc.get(\"args\"):\n            test_def[\"args\"] = tc[\"args\"]\n\n        def_path = os.path.join(TESTS_DIR, tier_name, f\"{name}.json\")\n        with open(def_path, \"w\") as f:\n            json.dump(test_def, f, indent=2)\n\n        manifest.append(test_def)\n        stats[tier][\"ok\"] += 1\n\n    # Write manifest\n    with open(os.path.join(EXPECTED_DIR, \"manifest.json\"), \"w\") as f:\n        json.dump(manifest, f, indent=2)\n\n    # Summary\n    print(\"\\n=== Curation complete ===\")\n    total_ok = 0\n    total_all = 0\n    for tier_num in sorted(SCOPE_TIERS):\n        s = stats[tier_num]\n        print(f\"  {TIER_NAMES[tier_num]}: {s['ok']}/{s['total']} tests\")\n        total_ok += s[\"ok\"]\n        total_all += s[\"total\"]\n    print(f\"  TOTAL: {total_ok}/{total_all} tests\")\n\n    # Create example fixtures for the agent workspace\n    create_examples()\n\n\ndef create_examples():\n    \"\"\"Copy a small subset of fixtures + expected outputs to workspace/examples.\"\"\"\n    examples_dir = EXAMPLES_SRC\n    os.makedirs(os.path.join(examples_dir, \"expected\"), exist_ok=True)\n\n    # Copy basic fixture (only if this scope actually built it; some scopes —\n    # e.g. the performance tier — do not use the `basic` fixture at all).\n    src = os.path.join(FIXTURES_DIR, \"basic\")\n    dst = os.path.join(examples_dir, \"basic\")\n    if not os.path.exists(src):\n        print(\"  (no 'basic' fixture in scope; skipping workspace examples)\")\n        return\n    if os.path.exists(dst):\n        shutil.rmtree(dst)\n    shutil.copytree(src, dst)\n\n    # Copy up to a handful of in-scope expected outputs for the basic fixture.\n    # Globbed (not hardcoded) so this works for whatever tier(s) are in scope;\n    # if the basic fixture is not used by this scope, nothing is copied.\n    import glob as _glob\n    basic_expected = sorted(_glob.glob(os.path.join(EXPECTED_DIR, \"t*_basic_*.expected\")))\n    for src_f in basic_expected[:6]:\n        base = os.path.basename(src_f)[: -len(\".expected\")]\n        shutil.copy2(src_f, os.path.join(examples_dir, \"expected\", f\"{base}.txt\"))\n\n    print(f\"  Examples written to {examples_dir}\")\n\n\nif __name__ == \"__main__\":\n    main()","lineStart":1,"lineEnd":789,"totalLines":789,"truncated":false}},"title":"rust-ls-color-advanced/environment/build_tests.py","time":{"start":1781082981659,"end":1781082981683}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_eb0d179b7001zB30LDYxkD5vIR","sessionID":"ses_14f2f6a1dffe5tjqcH5PnHscaJ","messageID":"msg_eb0d16d07001Tl9GUWp7wG7DUW"}}
