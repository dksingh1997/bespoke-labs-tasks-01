ke-labs-tasks-01/rust-ls-color-advanced/task.toml","text":"version = \"1.0\"\n\n[metadata]\ndifficulty = \"hard\"\ncategory = \"programming\"\ntags = [\"rust\", \"ls\", \"coreutils\", \"systems\", \"cli\", \"file-listing\", \"posix\", \"color\", \"ignore-patterns\"]\n\n[agent]\ntimeout_sec = 7200.0\nuser = \"agent\"\n\n[verifier]\ntimeout_sec = 3600.0\n\n[environment]\nbuild_timeout_sec = 600.0\ncpus = 2\nmemory_mb = 8192\nstorage_mb = 10240\ngpus = 0\nallow_internet = false\nmcp_servers = []\n\n[verifier.env]\n\n[solution.env]\n# Injected ONLY into oracle runs. solve.sh writes this token to an oracle marker\n# file and test.sh matches it to skip anti-cheat, because the oracle decrypts the\n# baked oracle `ls` as its solution. The agent never sees this value, so it cannot\n# forge the marker (replaces the old forgeable bare-existence .oracle_solution).\nHARBOR_ORACLE_FLAG = \"rustls_color_8b6ba5e882498aba\"","lineStart":1,"lineEnd":31,"totalLines":31,"truncated":false}},"title":"rust-ls-color-advanced/task.toml","time":{"start":1781082893404,"end":1781082893418}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_eb0d02a68001vQeqAFEa5cHONI","sessionID":"ses_14f307519ffe9pcxGOYtQjmgt2","messageID":"msg_eb0cfa4fb001jZ4yrc9wD1aQPb"}}
