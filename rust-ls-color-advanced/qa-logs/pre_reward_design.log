g_quote\", fx, [\"-lQ\"], 6)\n524:         add(f\"t6_{fx}_long_literal\", fx, [\"-lN\"], 6)\n525: \n526:     # Quoting on other fixtures too\n527:     for fx in [\"basic\", \"mixed\", \"symlinks\"]:\n528:         add(f\"t6_{fx}_escape\", fx, [\"-b\"], 6)\n529:         add(f\"t6_{fx}_quote_name\", fx, [\"-Q\"], 6)\n530:         add(f\"t6_{fx}_literal\", fx, [\"-N\"], 6)\n531:         add(f\"t6_{fx}_qs_c\", fx, [\"--quoting-style=c\"], 6)\n532:         add(f\"t6_{fx}_qs_shell\", fx, [\"--quoting-style=shell\"], 6)\n533: \n534:     # ===== TIER 7: Time & size formatting =====\n535:     for fx in [\"sizes\"]:\n536:         add(f\"t7_{fx}_human\", fx, [\"-lh\"], 7)\n537:         add(f\"t7_{fx}_si\", fx, [\"-l\", \"--si\"], 7)\n538:         add(f\"t7_{fx}_block_K\", fx, [\"-l\", \"--block-size=K\"], 7)\n539:         add(f\"t7_{fx}_block_M\", fx, [\"-l\", \"--block-size=M\"], 7)\n540:         add(f\"t7_{fx}_block_1\", fx, [\"-l\", \"--block-size=1\"], 7)\n541:         add(f\"t7_{fx}_block_1K\", fx, [\"-l\", \"--block-size=1K\"], 7)\n542:         add(f\"t7_{fx}_block_1M\", fx, [\"-l\", \"--block-size=1M\"], 7)\n543:         add(f\"t7_{fx}_human_size\", fx, [\"-sh\"], 7)\n544:         add(f\"t7_{fx}_kibi_size\", fx, [\"-sk\"], 7)\n545: \n546:     for fx in [\"timestamps\"]:\n547:         add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n548:         add(f\"t7_{fx}_ts_full_iso\", fx, [\"-l\", \"--time-style=full-iso\"], 7)\n549:         add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n550:         add(f\"t7_{fx}_ts_iso\", fx, [\"-l\", \"--time-style=iso\"], 7)\n551:         add(f\"t7_{fx}_ts_locale\", fx, [\"-l\", \"--time-style=locale\"], 7)\n552:         add(f\"t7_{fx}_ctime\", fx, [\"-lc\"], 7)\n553:         add(f\"t7_{fx}_atime\", fx, [\"-lu\"], 7)\n554:         add(f\"t7_{fx}_sort_ctime\", fx, [\"-ltc\"], 7)\n555:         add(f\"t7_{fx}_sort_atime\", fx, [\"-ltu\"], 7)\n556:         add(f\"t7_{fx}_time_word_atime\", fx, [\"-l\", \"--time=atime\"], 7)\n557:         add(f\"t7_{fx}_time_word_ctime\", fx, [\"-l\", \"--time=ctime\"], 7)\n558:         add(f\"t7_{fx}_ts_custom_fmt\", fx, [\"-l\", \"--time-style=+%Y-%m-%d\"], 7)\n559:         add(f\"t7_{fx}_ts_custom_fmt2\", fx, [\"-l\", \"--time-style=+%Y/%m/%d %H:%M\"], 7)\n560: \n561:     for fx in [\"basic\", \"mixed\"]:\n562:         add(f\"t7_{fx}_human_long\", fx, [\"-lh\"], 7)\n563:         add(f\"t7_{fx}_full_time\", fx, [\"--full-time\"], 7)\n564:         add(f\"t7_{fx}_ts_long_iso\", fx, [\"-l\", \"--time-style=long-iso\"], 7)\n565: \n566:     # ===== TIER 8: Color, hide/ignore, advanced, combos =====\n567:     for fx in [\"basic\", \"mixed\", \"symlinks\", \"permissions\", \"special_files\"]:\n568:         add(f\"t8_{fx}_color_always\", fx, [\"--color=always\"], 8,\n569:             env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n570:         add(f\"t8_{fx}_color_never\", fx, [\"--color=never\"], 8)\n571: \n572:     for fx in [\"basic\", \"mixed\", \"permissions\"]:\n573:         add(f\"t8_{fx}_color_long\", fx, [\"-l\", \"--color=always\"], 8,\n574:             env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n575: \n576:     add(\"t8_symlinks_color_long\", \"symlinks\", [\"-l\", \"--color=always\"], 8,\n577:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n578:     add(\"t8_special_files_color_classify\", \"special_files\",\n579:         [\"-F\", \"--color=always\"], 8,\n580:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n581: \n582:     for fx in [\"backups\"]:\n583:         add(f\"t8_{fx}_ignore_backups\", fx, [\"-B\"], 8)\n584:         add(f\"t8_{fx}_ignore_backups_l\", fx, [\"-lB\"], 8)\n585: \n586:     for fx in [\"basic\", \"mixed\"]:\n587:         add(f\"t8_{fx}_ignore_pattern\", fx, [\"-I\", \"*.txt\"], 8)\n588:         add(f\"t8_{fx}_hide_pattern\", fx, [\"--hide=*.txt\"], 8)\n589:         add(f\"t8_{fx}_ignore_l\", fx, [\"-lI\", \"*.txt\"], 8)\n590: \n591:     add(\"t8_mixed_context\", \"mixed\", [\"-Z\"], 8)\n592:     add(\"t8_mixed_context_long\", \"mixed\", [\"-lZ\"], 8)\n593:     add(\"t8_permissions_context_long\", \"permissions\", [\"-lZ\"], 8)\n594: \n595:     # Multi-flag combos\n596:     add(\"t8_combo_laSr\", \"mixed\", [\"-laSr\"], 8)\n597:     add(\"t8_combo_latr\", \"timestamps\", [\"-latr\"], 8)\n598:     add(\"t8_combo_lhS\", \"sizes\", [\"-lhS\"], 8)\n599:     add(\"t8_combo_RlF\", \"deep\", [\"-RlF\"], 8)\n600:     add(\"t8_combo_lisg\", \"permissions\", [\"-lisg\"], 8)\n601:     add(\"t8_combo_color_classify_R\", \"mixed\",\n602:         [\"-RlF\", \"--color=always\"], 8,\n603:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n604:     add(\"t8_combo_quote_color\", \"special_names\",\n605:         [\"-Q\", \"--color=always\"], 8,\n606:         env_extra={\"LS_COLORS\": LS_COLORS_VAL})\n607:     add(\"t8_override_f_then_l\", \"basic\", [\"-fl\"], 8)\n608:     add(\"t8_override_l_then_1\", \"basic\", [\"-l\", \"-1\"], 8)\n609:     add(\"t8_override_C_then_l\", \"basic\", [\"-C\", \"-l\"], 8)\n610:     add(\"t8_override_1_then_C\", \"basic\", [\"-1\", \"-C\"], 8)\n611: \n612:     # ===== TIER 9: Performance =====\n613:     add(\"t9_perf_no_flags\", \"perf_10k\", [], 9, timeout=60)\n614:     add(\"t9_perf_one_col\", \"perf_10k\", [\"-1\"], 9, timeout=60)\n615:     add(\"t9_perf_long\", \"perf_10k\", [\"-l\"], 9, timeout=60)\n616:     add(\"t9_perf_sort_size\", \"perf_10k\", [\"-S\"], 9, timeout=60)\n617:     add(\"t9_perf_columns\", \"perf_10k\", [\"-C\"], 9, timeout=60)\n618: \n619:     return tests\n620: \n621: \n622: # ---------------------------------------------------------------------------\n623: # Oracle runner\n624: # ---------------------------------------------------------------------------\n625: \n626: def run_oracle(fixture, flags, env_extra=None, args=None):\n627:     \"\"\"Run oracle ls and return (stdout, stderr, returncode).\"\"\"\n628:     env = make_env(**(env_extra or {}))\n629:     fx_path = fixture_path(fixture)\n630: \n631:     if args:\n632:         full_args = [os.path.join(fx_path, a) for a in args]\n633:     else:\n634:         full_args = [fx_path]\n635: \n636:     cmd = [ORACLE_LS] + flags + full_args\n637: \n638:     try:\n639:         result = subprocess.run(\n640:             cmd,\n641:             capture_output=True,\n642:             env=env,\n643:             timeout=TIMEOUT,\n644:         )\n645:         return result.stdout.decode(\"utf-8\", errors=\"replace\"), result.returncode\n646:     except subprocess.TimeoutExpired:\n647:         return None, -1\n648:     except Exception as e:\n649:         print(f\"  ERROR running oracle: {e}\", file=sys.stderr)\n650:         return None, -1\n651: \n652: \n653: def normalize_output(text):\n654:     \"\"\"Strip trailing whitespace from each line.\"\"\"\n655:     lines = text.split(\"\\n\")\n656:     cleaned = [l.rstrip() for l in lines]\n657:     while cleaned and cleaned[-1] == \"\":\n658:         cleaned.pop()\n659:     return \"\\n\".join(cleaned) + \"\\n\" if cleaned else \"\"\n660: \n661: \n662: # ---------------------------------------------------------------------------\n663: # Main\n664: # ---------------------------------------------------------------------------\n665: \n666: TIER_NAMES = {\n667:     1: \"tier1_basic\",\n668:     2: \"tier2_long_format\",\n669:     3: \"tier3_sorting\",\n670:     4: \"tier4_formatting\",\n671:     5: \"tier5_symlinks_recursion\",\n672:     6: \"tier6_quoting_escaping\",\n673:     7: \"tier7_time_size\",\n674:     8: \"tier8_color_advanced\",\n675:     9: \"tier9_performance\",\n676: }\n677: \n678: \n679: def main():\n680:     print(\"=== Defining test cases ===\")\n681:     test_cases = [tc for tc in define_test_cases() if tc[\"tier\"] in SCOPE_TIERS]\n682:     print(f\"  In-scope tiers: {sorted(SCOPE_TIERS)}\")\n683:     print(f\"  Total test cases: {len(test_cases)}\")\n684: \n685:     print(\"=== Creating fixtures ===\")\n686:     needed = {tc[\"fixture\"] for tc in test_cases}\n687:     create_all_fixtures(needed)\n688: \n68